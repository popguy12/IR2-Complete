Class HealthPool : Health
{
	Default
	{
	Inventory.Amount 1000000;
	Inventory.MaxAmount 1000000;
	-INVENTORY.ALWAYSPICKUP
	}
}

Class IR2EssenceBase : HealthPool abstract
{
	color h;
	property HexCol : h;
	string s;
	property Sprite : s;
	
	Default
	{
	XScale 0.4;
    YScale 0.332;
	IR2EssenceBase.HexCol "2143b5";
	IR2EssenceBase.Sprite "C_R1";
	Gravity 0.25;
	//+FLOATBOB
	+FLOAT
    -NOGRAVITY
    +NOTIMEFREEZE
	+INVENTORY.ALWAYSPICKUP
	+COUNTITEM
	+NEVERRESPAWN
	+VISIBILITYPULSE
	+BRIGHT
	//FloatBobStrength 0.125;
	ActiveSound "Spirit/Active";
	Inventory.PickupSound "Spirit/EsscenseAbsorb";
	Renderstyle "Translucent";
	Height 16;
	Radius 20;
	Inventory.Amount 5;
	}
	
	bool EssenceCheck(double distance)
	{			
		for (int i = 0; i < MAXPLAYERS; i++)
			if(playeringame[i] && CheckSight(players[i].mo) && !CheckRange(distance))
				return true;
		
		return false;
	}
	
	override void Tick()
	{
		super.Tick();
		
		//In order to reduce lag and improve peformance
		if (EssenceCheck(900)) A_SpawnParticleEx(h, TexMan.CheckForTexture("C_R_Z0"), STYLE_ADD, SPF_FULLBRIGHT|SPF_RELATIVE|SPF_NOTIMEFREEZE|SPF_ROLL, 50, random(10, 50) + scale.x, 0, frandom(-5, 5), frandom(-5, 5), 10 + frandom(-5, 5), frandom(-0.5, 0.5), frandom(-0.5, 0.5), frandom(-0.5, 0.5), accelz: 0.01, startalphaf: 1, fadestepf: 0.015, sizestep: -0.525, startroll: frandom(0, 360));
	}
	
	override void PostBeginPlay()
	{
		super.PostBeginPlay();
		sprite = GetSpriteIndex(s);
		scale /= 0.5;
		alpha += 0.77;
	}
	
	States
	{
	LoadSprites:
		C_R1 ABBCDDEFFGHHIJJKLLMNNOPPQRRSTTU 0;
		C_R2 ABBCDDEFFGHHIJJKLLMNNOPPQRRSTTU 0;
		C_R3 ABBCDDEFFGHHIJJKLLMNNOPPQRRSTTU 0;
		C_R4 ABBCDDEFFGHHIJJKLLMNNOPPQRRSTTU 0;
		C_R5 ABBCDDEFFGHHIJJKLLMNNOPPQRRSTTU 0;
		C_R6 ABBCDDEFFGHHIJJKLLMNNOPPQRRSTTU 0;
	Spawn:
		#### ABBCDDEFFGHHIJJKLLMNNOPPQRRSTTU 1;
		goto Spawn;
	}
}

