CLASS BloodSweetener: Actor
{
	Default
	{
	+NOBLOCKMAP
	+NOTELEPORT
	+ALLOWPARTICLES
	+ROLLSPRITE
	renderstyle "translucent";
	alpha 0.88;
	gravity 0.1;
	scale 0.320;
	}
	States
	{
	Spawn:
		TNT1 A 0;
		TNT1 A 0 A_Jump(256,"Spawn1","Spawn2");
		stop;
	Spawn1:
		TNT1 A 0 A_SetRoll(random(0, 359));
		TNT1 A 0 A_Jump(127,2);
		TNT1 A 0 A_SetScale (scaleX * 1.256 ,scaleY * 1.256);
		3LUT ABCDE 1;
		goto Fadeout;
	Spawn2:
		TNT1 A 0 A_SetRoll(random(0, 359));
		TNT1 A 0 A_Jump(127,3);
		TNT1 A 0 A_SetScale (scaleX * 1.155 ,scaleY * 1.155);
		TNT1 A 0 A_Jump(256,2);
		TNT1 A 0 A_SetScale (scaleX * 1.192 ,scaleY * 1.192);
		4LUT ABCDE 1;
		goto Fadeout;
	Fadeout:
		"####" FGHIJ 1 A_FadeOut(0.1,FTF_REMOVE|FTF_CLAMP);
		Loop;
	}
}

CLASS BloodImpact: Actor
{
	Default
	{
	+NOBLOOD
	+NOBLOCKMAP
	+NOBLOCKMONST
	+NOTELEPORT
	-ALLOWPARTICLES
	+FORCEXYBILLBOARD
	+FLOORCLIP
	+NOGRAVITY
	+LOWGRAVITY
	+ROLLSPRITE
	RenderStyle "Translucent";
	Alpha 0.88;
	Scale 0.480;
	}
	States
	{
	
	Spawn:
		TNT1 A 0;
		TNT1 A 0 A_Jump(256,"Spawn1","Spawn2","Spawn3");
		Stop;
		
	Spawn1:
		TNT1 A 0 Nodelay A_SetRoll(random(0, 359));
		TNT1 A 0 A_SetScale (scaleX * 1.256 ,scaleY * 1.256);
		BDHT ABCD 1;
		goto Fadeout;
		
	Spawn2:
		TNT1 A 0 Nodelay A_SetRoll(random(0, 359));
		TNT1 A 0 A_SetScale (scaleX * 1.155 ,scaleY * 1.155);
		BDHT ABCD 1;
		goto Fadeout;

	Spawn3:
		TNT1 A 0 Nodelay A_SetRoll(random(0, 359));
		TNT1 A 0 A_SetScale (scaleX * 1.128 ,scaleY * 1.128);
		BDHT ABCD 1;
		goto Fadeout;
	Fadeout:
		BDHT EFGH 1 A_FadeOut(0.1,FTF_REMOVE|FTF_CLAMP);
		Loop;
	}
}

Class DusterCoinShot : FastProjectile
{
	Default
	{
	Radius 10;
	Height 14;
	Speed 250;
	Scale 0.45;
	Damage 180;
	MissileType "DusterWPSmokeHarmless";
	Decal "None";
	DamageType "Cutless";
	PROJECTILE;
	+HITTRACER
	+BLOODSPLATTER
	Renderstyle "Add";
	Obituary "%o caught a fist full of nickels, courtesy of %k.";
	MissileHeight 3;
	}
	states
	{
	Spawn:
		TNT1 A 1;
    Looper:
		PUFF A 1;
		loop;
	Death:
		TNT1 A 0 A_StartSound("CoinShot/Scatter",998,0,1.0,2);
		TNT1 AAAAAAAAA 0 A_SpawnItemEx ("SilverCoinFly", 0, 0, 0, frandom(0.5,1.0), random(3,5) , random(0,6) , random(0,180));
		TNT1 AAAAAAA 0 A_SpawnItemEx ("SilverCoinFly", 0, 0, 0, frandom(0.5,1.0), random(3,5) , random(0,6) , random(0,180));
		TNT1 AAAAA 0 A_SpawnItemEx ("SilverCoinFly", 0, 0, 0,  0, frandom(-0.3,0.3) , frandom(0,0.35) , random(0,180));
		TNT1 AAAAAAAAA 0 A_CustomMissile ("NormHitSpark1", 2, 0, frandom(0,1)*frandom (0, 360), 2, frandom(0,1)*frandom (30, 360));
		TNT1 AAAAAAA 0 A_CustomMissile ("NormHitSpark2", 2, 0, frandom(0,1)*frandom (0, 360), 2, frandom(0,1)*frandom (30, 360));
		TNT1 AAAAA 0 A_CustomMissile ("NormHitSpark3", 2, 0, frandom(0,1)*frandom (0, 360), 2, frandom(0,1)*frandom (30, 360));
		TNT1 A 1 A_SpawnItemEx("HAC_ImpactPuff",0,0,0,0,0);
		stop;
	
	XDeath:
		TNT1 A 0 A_StartSound("CoinShot/Scatter",999,0,1.0,2);
		TNT1 AAAAAAAAA 0 A_SpawnItemEx ("SilverCoinFly2", 0, 0, 0, frandom(0.5,1.0), random(3,5) , random(0,6) , random(0,180));
		TNT1 AAAAAAA 0 A_SpawnItemEx ("SilverCoinFly2", 0, 0, 0, frandom(0.5,1.0), random(3,5) , random(0,6) , random(0,180));
		TNT1 AAAAA 0 A_SpawnItemEx ("SilverCoinFly2", 0, 0, 0,  0, frandom(-0.3,0.3) , frandom(0,0.35) , random(0,180));
		TNT1 AAAAAAAAA 0 A_CustomMissile ("NormHitSpark1", 2, 0, frandom(0,1)*frandom (0, 360), 2, frandom(0,1)*frandom (30, 360));
		TNT1 AAAAAAA 0 A_CustomMissile ("NormHitSpark2", 2, 0, frandom(0,1)*frandom (0, 360), 2, frandom(0,1)*frandom (30, 360));
		TNT1 AAAAA 0 A_CustomMissile ("NormHitSpark3", 2, 0, frandom(0,1)*frandom (0, 360), 2, frandom(0,1)*frandom (30, 360));
		TNT1 A 1 A_SpawnItemEx("HAC_ImpactPuff",0,0,0,0,0);
		stop;
	}
}

Class SilverCoinFly : Actor
{
	Default
	{
	Radius 2;
    Height 4;
    Speed 8;
    XScale 0.1;
    YScale 0.1;
    BounceSound "CoinShot/Bounce";
    PROJECTILE;
    Damage 1;
    -NOGRAVITY
    +BOUNCEONACTORS
    +BOUNCEONWALLS
    +BOUNCEONFLOORS
    +BOUNCEONCEILINGS
    -DONTSPLASH
    +ROLLSPRITE
	+RIPPER
    Gravity 0.75;
    BounceCount 6;
    BounceFactor 0.66;
    DamageType "Cutless";
	Renderstyle "Normal";
	}
	states{
	Spawn:
	  TNT1 A 0 NODELAY A_Countdown;
	  TNT1 A 0 ThrustThingZ(0,5,0,0);
	  TNT1 A 0 ThrustThing(0,(frandom(-16, 16)));
      Goto Roflcopter;
    Roflcopter:
      1104 A 1 A_SetRoll(roll+15, SPF_INTERPOLATE);
      Loop;
    Death:
	  TNT1 A 0 A_SetRoll(0);
      TNT1 A 0 A_SpawnItemEx("SilverCoinDebris");
      stop;
   }
}

Class SilverCoinDebris : Actor
{
	Default
	{
	-NOGRAVITY
	Renderstyle "Normal";
	XScale 0.1;
    YScale 0.1;
	}
	states{
	Spawn:
	  TNT1 A 0;
	  TNT1 A 0 A_Jump(255,"Spawn1","Spawn2","Spawn3");
	  stop;
	Spawn1:
	  1104 A 1;
	  Goto Ded;
	Spawn2:
	  1104 A 1;
	  Goto Ded;
	Spawn3:
	  1104 A 1;
	  Goto Ded;
	Ded:
	  "####" "#" 210 A_CheckSight("Fadying");
	  Loop;
	Fadying:
	  "####" "#" 1 A_FadeOut(0.1);
	  Wait;
	}
}

