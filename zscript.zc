Class FlamethrowerMissileNew : actor
{
	default {
		Radius 12;
		Height 8;
		Speed 28;
		Damage 5;
		+NOBLOCKMAP;
		+NOTELEPORT;
		+DONTSPLASH;
		+MISSILE;
		+FORCEXYBILLBOARD;
		+Randomize;
		-RIPPER;
		+NOBLOOD;
		+NOBLOODDECALS;
		+BLOODLESSIMPACT;
		-BLOODSPLATTER;
		+ROLLSPRITE
		+HitMaster;
		RenderStyle "Add";
		DamageType "Fire";
		Scale 1;
		Gravity 0;
	}
	States {
		Spawn:
			TNT1 A 0;
			DB55 AB 1 BRIGHT{ 
			A_Setscale(.3);
			A_Setroll(Random(0,359));
			}
			DB55 CDEFG 1 BRIGHT{
			A_Setscale(.5);
			A_Setroll(roll+random(1,5));
			}
			DB55 HIJKL 1 BRIGHT{
			A_Setscale(.8);
			A_Setroll(roll+random(1,5));
			}
			DB55 MNOP 1 BRIGHT{
			A_Setscale(1.0);
			A_Setroll(roll+random(1,5));
			}
			DB55 QRSTU 1 BRIGHT{
			A_Setscale(1.1);
			A_Setroll(roll+random(1,5));
			}
			DB55 VWXY 1 BRIGHT{
			A_Setscale(1.3);
			A_Setroll(roll+random(1,5));
			}
			DB55 Z 1 BRIGHT{
				A_Explode(1, 120, 0);
			}
		Death:
			TNT1 A 0 A_Explode(8, 150, 0);
			TNT1 A 0 A_CheckFloor(1);
			Goto DeathContinue;
			TNT1 A 0;
			TNT1 A 0 A_SpawnItemEx("FT_GroundFireSpawner", random (-25, 25), random (-15, 15),0,5);
		DeathContinue:
			EXPL A 0 A_SpawnProjectile ("FlamethrowerFireParticles", 6, 0, random (0, 360), 2, random (10, 90));
			DB54 EFGHIJKLMNOPQR 1 BRIGHT;
			Stop;
			
			
		SpawnFlames:
					TNT1 A 0 {
        if(GetCVar("pb_performance_fire") == false) 
        {
        } 
        else 
        { 
        }
			}
			EXPL A 0 A_SpawnProjectile ("FlamethrowerFireParticles", 6, 0, random (0, 360), 2, random (10, 90));
			DB54 EFGHIJKLMNOPQR 1 BRIGHT;
			Stop;
			
		XDeath:
			TNT1 A 0 A_Explode(9, 150, 0);
			EXPL A 0 A_SpawnProjectile ("FlamethrowerFireParticles", 6, 0, random (0, 360), 2, random (10, 90));
			
			TNT1 A 0 {
				Actor pointer_collided = master; 
				if (pointer_collided && !(pointer_collided.GetSpecies() == "Hitbox")) {
					bPAINLESS = true;
					bTHRUACTORS = true;
					bSOLID = false;
					A_AttachLightDef('FlamethrowerLight',"IncinerationGlowSmall");
				}
				else {
						self.SetState(FindState("Death"));
						return;
				}
			}
		StickOnActor:
			TNT1 A 1 {
				
				if (master) {
					
// 					A_Explode(random(0,1), 20, 0);
					A_SpawnItemEx("FT_GroundFire", random(1,-1), (master.radius/2)+random(-12,12), (master.height/2)+random(-16,16),random(-1,1), Flags: SXF_NOCHECKPOSITION);
					A_SpawnItemEx("FT_GroundFire", random(1,-1), (master.radius/2)+random(-12,12), (master.height/2)+random(-16,16),random(-1,1), Flags: SXF_NOCHECKPOSITION);
					A_DamageMaster(random(0,1), "Fire");
				}
				
			}
			TNT1 A 0 A_JumpIfHealthLower(0, "DieOut", AAPTR_MASTER);
			TNT1 A 0 A_Jump(4, "DieOut");
			TNT1 A 1 A_Warp(AAPTR_MASTER, 0, 0, 0, 0, 0, "StickOnActor");
			Stop;
			
		DieOut:
			TNT1 A 0 A_RemoveLight('FlamethrowerLight');
			Stop;
	
	}
}
