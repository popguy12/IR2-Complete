   Slider "X Position",	"ucm_yoffset", -30, 9999, 1, 0
   SubMenu "Map Alignment", "UCMOptions_Alignment"
   StaticText " "
   Slider "Size", "ucm_mapsize", 32, 512, 1, 0
   Option "Fullscreen",	"ucm_drawfullscreen", "YesOrNo"
   StaticText " "
