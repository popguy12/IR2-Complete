ListMenu "MainMenu"
{
	Selector "G_COLON1", -32, -5
    Linespacing 22
	StaticPatch 94, 22, "TNT1A0"
	Position 72, 80
	PatchItem "G_CONFIG","c", "IR2Settings"
	PatchItem "G_NGAME", "n", "PlayerClassMenu"
	PatchItem "G_LGAME", "l", "LoadGameMenu"
	PatchItem "G_SGAME", "s", "SaveGameMenu"
	PatchItem "G_OPTION","o", "OptionsMenu"
	PatchItem "G_QGAME", "q", "QuitMenu"

}



ListMenu "SkillMenu"
{
		StaticPatch 54, 38, "G_CHSSKL"
		Selector "G_COLON2", -72, -5
		Position 48, 63
}

OptionMenu "IR2Settings"
{
	Title "Mod Settings"
	StaticText "Enable, or disable Ryan's ability to double jump."
	Option "Double Jumping", "jpm_enable_djump", "OnOff"
	StaticText ""
	StaticText "Mobility Dashing Style, The options presented should be self explanitory."
	Option "Mobility Dashing", "tb_dashholdspeed", "DashingYesNo"
	StaticText ""
	StaticText "Allows Ryan to crouch slide under low gaps, hold sprint and press crouch"
	Option "Crouch Sliding", "jpm_enable_slide", "OnOff"
	StaticText ""
	StaticText "Poor performance? Give this setting a go."
	StaticText ""
	Slider "Barrel Parts",		"IR2_BarrelAmount",			0, 20, 1, 0
	Option "Particle Choker",	"ir_perfmode",	"ChokerList"
	StaticText ""
	Option "Monster Spawn Type",	"ir2_replacemonsters",	"IR2MonsYesNo"
	Option "Tracer Damage Variable",	"ir2_replacetracers",	"IR2BulletsYesNo"
	StaticText ""
	StaticText "Don't like my enemy roster? Wanna use Brutal Enemies? now you can disable them."
	StaticText "Now you can also change the tracer variable to support Brutal Style Shitboxes"
	StaticText "Map Restart Required"
	StaticText ""
	StaticText "These should be obvious."
	StaticText ""
	Submenu "Customize Droplets", "BloodOptions"
	Submenu "Customize Tilt++", "TiltPlusPlusMenu"
	Submenu "Customize HitMarkers", "HM_Options"
	Submenu "UCMinimap Options", "UCMOptions"
	StaticText ""
	StaticText "Automatic Reloading never was, and never will be a part of this mod, you know who you are."
}

OptionValue "ChokerList"
{
	0, "Regular SFX Particles"		//Normal number of particles
	1, "50% Particle Reduction"		//50% less particles
	2, "80% Particle Reduction"		//80% less particles
	3, "SFX Particles Disabled"	//No particles
}

OptionValue "DashingYesNo"
{
	0, "Just Double Tap" //This is easier to time, but is far more likely to cause unintentional death.
	1, "Hold + Double Tap" //This makes you less likely to dash off a cliff to your death accidentally, but is also a bit trickier to master.

}

OptionValue "IR2MonsYesNo"
{
	0, "Alternate, or Vanilla Spawns" //I'm a little bitch who cant handle the mod's intended difficulty and playstyle. I could also just wanna play with different monsters
	1, "IR2 Monster Spawns" //I can take the beating the monsters like to dish out so bring it on motherfuckers!

}

OptionValue "IR2BulletsYesNo"
{
	0, "Full Damage IR2 Tracers"		//>But Tibr M-M-Muh Burtael Munshters!111!!!!1ONE!
	1, "Weaker Vanilla-ish Tracers"	//Now enemies shouldnt gib when shooting them with my guns.

}

OptionValue "BloodAmount"
{
	0, "Mild"
	1, "Normal"
	2, "Excessive"
}

OptionMenu "BloodOptions"
{
	Title "Blood Options"
	Option "Blood Amount", "blood_amt", "BloodAmount"
	StaticText " "
	Slider "Blood Gravity", "blood_grav", 0.0, 1.0, 0.05, 2
	Slider "Blood Opacity", "blood_alpha", 0.5, 1.0, 0.05, 2
	Slider "Blood Scale", "blood_size", 0.5, 1.5, 0.05, 2
	Slider "Blood Velocity", "blood_rand", 0.5, 2.0, 0.05, 2
	StaticText " "
	Slider "Blood Limit", "sv_corpsequeuesize", 64, 4096, 64, 0
	Slider "Decal Limit", "cl_maxdecals", 64, 4096, 64, 0
	StaticText " "
	Option "Spawn Blood Mist", "blood_mist", "onoff"
	Option "Spawn Blood Pools", "blood_pools", "onoff"
	Option "Spawn Giblets", "blood_gibs", "onoff"
	Option "Chunky Mode", "blood_chunky", "onoff"
	Option "Ludicrous Gibs", "blood_alwaysgib", "onoff"
	Option "Blood Droplets Spatter", "blood_splash", "onoff"
	StaticText "WARNING: This option can significantly increase the number of"
	StaticText "blood droplets spawned in-game."
}

OptionMenu "TiltPlusPlusMenu"
{
	Class "TiltPlusPlusMenu"
	Title "Immerse Options"

	StaticText ""
	StaticText "$TILTPLUSPLUSMNU_STRAFETILT_TITLE"
	TiltPlusPlusOption "$TILTPLUSPLUSMNU_ENABLED",					"$TILTPLUSPLUSMNU_HELPTEXT_STRAFETILT",				"sv_strafetilt", "YesNo"
	TiltPlusPlusOption "$TILTPLUSPLUSMNU_STRAFETILT_REVERSED",		"$TILTPLUSPLUSMNU_HELPTEXT_STRAFETILT_REVERSED",	"sv_strafetiltreversed", "YesNo"
	TiltPlusPlusSlider "$TILTPLUSPLUSMNU_SPEED",					"$TILTPLUSPLUSMNU_HELPTEXT_STRAFETILT_SPEED",		"sv_strafetiltspeed", 0.1, 2.0, 0.01, 2
	TiltPlusPlusSlider "$TILTPLUSPLUSMNU_ANGLE",					"$TILTPLUSPLUSMNU_HELPTEXT_STRAFETILT_ANGLE",		"sv_strafetiltangle", 0.1, 1.0, 0.01, 2

	StaticText ""
	StaticText "$TILTPLUSPLUSMNU_MOVETILT_TITLE"
	TiltPlusPlusOption "$TILTPLUSPLUSMNU_ENABLED",					"$TILTPLUSPLUSMNU_HELPTEXT_MOVETILT",				"sv_movetilt", "YesNo"
	TiltPlusPlusSlider "$TILTPLUSPLUSMNU_SPEED",					"$TILTPLUSPLUSMNU_HELPTEXT_MOVETILT_SPEED",			"sv_movetiltspeed", 0.1, 20.0, 0.1, 2
	TiltPlusPlusSlider "$TILTPLUSPLUSMNU_ANGLE",					"$TILTPLUSPLUSMNU_HELPTEXT_MOVETILT_ANGLE",			"sv_movetiltangle", 0.01, 0.10, 0.01, 2
	TiltPlusPlusSlider "$TILTPLUSPLUSMNU_SCALAR",					"$TILTPLUSPLUSMNU_HELPTEXT_MOVETILT_SCALAR",		"sv_movetiltscalar", 0.0, 1.0, 0.1

	StaticText ""
	StaticText "$TILTPLUSPLUSMNU_UNDERWATERTILT_TITLE"
	TiltPlusPlusOption "$TILTPLUSPLUSMNU_ENABLED",					"$TILTPLUSPLUSMNU_HELPTEXT_UNDERWATERTILT",			"sv_underwatertilt", "YesNo"
	TiltPlusPlusSlider "$TILTPLUSPLUSMNU_SPEED",					"$TILTPLUSPLUSMNU_HELPTEXT_UNDERWATERTILT_SPEED",	"sv_underwatertiltspeed", 0.1, 20.0, 0.1, 2
	TiltPlusPlusSlider "$TILTPLUSPLUSMNU_ANGLE",					"$TILTPLUSPLUSMNU_HELPTEXT_UNDERWATERTILT_ANGLE",	"sv_underwatertiltangle", 0.01, 0.5, 0.01, 2
	TiltPlusPlusSlider "$TILTPLUSPLUSMNU_SCALAR",					"$TILTPLUSPLUSMNU_HELPTEXT_UNDERWATERTILT_SCALAR",	"sv_underwatertiltscalar", 0.0, 1.0, 0.1

	StaticText ""
	StaticText "$TILTPLUSPLUSMNU_DEATHTILT_TITLE"
	TiltPlusPlusOption "$TILTPLUSPLUSMNU_ENABLED",					"$TILTPLUSPLUSMNU_HELPTEXT_DEATHTILT",				"sv_deathtilt", "YesNo"
	
	StaticText ""
	StaticText "Leaning"
	Slider "Lean Angle", "sv_leanangle", 11.25, 90.0, 11.25
	StaticText "The default and recommended lean angle is 22.5"
	
	StaticText ""
	StaticText "Real Aim"
	Option "Sync Move Tilt to Real Aim", "sv_syncmovetilt", "YesNo"
	Option "Springy Mouselook", "sv_realaimspring", "YesNo"
	Option "Sway Camera", "sv_realaimtoggle", "YesNo"
	Slider "Sway Multiplier", "sv_realaimsway", 0.5, 2.0, 0.25
	Slider "Sway Rate", "sv_realaimrate", 0.5, 1.5, 0.125
	
	StaticText ""
	StaticText "Footsteps"
	Option "Play Footstep Sounds", "sv_playFootsteps", "YesNo"
	Slider "Volume", "sv_footstepVolume", 0.25, 2.0, 0.25
}

OptionMenu "HM_Options"
{
	Title "HitMarkers Options"
	Option "Enable HitMarkers", "hm_enabled", "HM_YesNo"
	StaticText ""
	StaticText "General Options", 1
	Slider "Fade Time in Seconds", "hm_fade", 0.1, 1.5, 0.1, 2
	Slider "Opacity Percentage", "hm_opacity", 10, 100, 1, 0
	StaticText ""
	StaticText "Hit Marker Options", 1
	Option "Show Hit Markers", "hm_showhitmarkers", "HM_YesNo"
	Option "Hit Animation Speed", "hm_hitspeed", "HM_Speed"
	Option "Hit Marker Style", "hm_hitstyle", "HM_Style"
	Option "Show Kill Markers", "hm_showkillmarkers", "HM_YesNo"
	Option "Kill Animation Speed", "hm_killspeed", "HM_Speed"
	Option "Kill Marker Style", "hm_killstyle", "HM_Style"
	StaticText ""
	StaticText "Hit Sound Options", 1
	StaticText "Hit sounds function independently from"
	StaticText "hit markers. You can customize the sounds"
	StaticText "for both standard impacts and enemy kills."
	StaticText ""
	Option "Use Hit Sounds", "hm_hitsounds", "HM_YesNo"
	Option "Hit Sound Type", "hm_hitsound", "HM_HitSound"
	Option "Use Kill Sounds", "hm_killsounds", "HM_YesNo"
	Option "Kill Sound Type", "hm_killsound", "HM_KillSound"
	Option "Limit Rapid Sounds", "hm_soundlimit", "HM_YesNo"
	Slider "Volume Percentage", "hm_volume", 1, 100, 1, 0
	StaticText ""
	StaticText "Hit Damage Options", 1
	StaticText "You can modify the type of hit sounds"
	StaticText "that play based on the amount of damage"
	StaticText "done to enemies."
	StaticText ""
	Option "Use Damage Hit Sounds", "hm_hitdamage", "HM_YesNo"
	Slider "High Damage Hit", "hm_hitdamagehigh", 1, 1000, 1, 0
	Slider "Medium Damage Hit", "hm_hitdamagemedium", 1, 1000, 1, 0
}

