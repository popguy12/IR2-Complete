      RFR1 G 3 A_Pain 
      Goto See
   Reload_Check:
	  TNT1 A 0 A_JumpIfCloser(1000, "retreat")
   Reload:
	  RFR1 E 9 A_PlaySound("ArchangelK61/MagOut")
	  RFR1 E 18 A_PlaySound("ArchangelK61/MagIn")
	  RFR1 E 9 A_PlaySound("ArchangelK61/BoltCatch")
	  TNT1 A 0 A_TakeInventory("RifleGuy_Ammo", 999)
	  TNT1 A 0 A_TakeInventory("RifleGuy_RetreatTimer", 99)
	  Goto See
   Retreat:
	  TNT1 A 0 A_JumpIfInventory("RifleGuy_RetreatTimer", 10, "Reload")
	  RFR1 ABCD 2 A_Wander
	  TNT1 A 0 A_GiveInventory("RifleGuy_RetreatTimer", 1)
	  loop
   Death.MagnumBullet:
   Death.ShotgunPellet:
   Death.CannonBullet:
	  //
      TNT1 A 0 A_GiveToTarget("ShitMyPlayerSaysWhenHeKillsShit",1)
      TNT1 A 0 A_GiveToTarget("PlayerScore",15)
      RFR1 H 3 A_FaceTarget
	  TNT1 A 0 A_Recoil(30)
	  TNT1 A 0 ThrustThingZ(0,20,0,1)
      RFR1 I 3 A_Scream 
      RFR1 J 3 A_Fall 
      RFR1 K 3
	  RFR1 L -1
	  Stop
   Death:
      //
      TNT1 A 0 A_GiveToTarget("ShitMyPlayerSaysWhenHeKillsShit",1)
      TNT1 A 0 A_GiveToTarget("PlayerScore",15)
      RFR1 H 3 
      RFR1 I 3 A_Scream 
      RFR1 J 3 A_Fall 
      RFR1 K 3
	  RFR1 L -1 
      Stop
	Death.PointBlank:
    XDeath:
	  //
	  TNT1 A 0 A_GiveToTarget("ShitMyPlayerSaysWhenHeKillsShit",1)
	  TNT1 A 0 A_GiveToTarget("PlayerScore",30)
	  TNT1 A 0 A_NoBlocking
      RFR1 MNO 3 A_XScream
      RFR1 P 3 A_Fall
      RFR1 QRS 3
	  RFR1 T -1
      Stop
	  Burn:
		TNT1 A 0 A_GiveToTarget("ShitMyPlayerSaysWhenHeSetsShitOnFire",1)
	    TNT1 A 0 A_GiveToTarget("PlayerScore",60)
		Death.Fire:
		RFR1 A 0 A_PlaySound("GNZombie/Pain")
		RFR1 A 0 A_SpawnItemEx("FlameTrails",0,0,32)
		RFR1 A 0 A_Recoil(-8)
		RFR1 A 0 A_SpawnItemEx("Heavy_Ember",0,0,32)
		RFR1 AAAA 1 A_SetAngle(12 + angle)
		RFR1 B 0 A_Recoil(-8)
		RFR1 A 0 A_SpawnItemEx("SmallFlameTrails",0,0,32)
		RFR1 BBBB 1 A_SetAngle(12 + angle)
		RFR1 C 0 A_Recoil(-8)
		RFR1 A 0 A_SpawnItemEx("FlameTrails",0,0,32)
		RFR1 CCCC 1 A_SetAngle(12 + angle)
		RFR1 D 0 A_Recoil(-8)
		RFR1 DDDD 1 A_SetAngle(12 + angle)
		RFR1 A 0 A_SpawnItemEx("FlamethrowerFireParticles",0,0,32)
		RFR1 A 0 A_Jump(128,"Death.Fire")
		BURN A 3 Bright A_PlaySound("misc/burn", CHAN_AUTO)
		BURN B 3 Bright A_Scream
		BURN C 3 Bright A_PlaySound("misc/flame", CHAN_AUTO)
		BURN D 3 Bright A_NoBlocking
		BURN EFGHIJKLMNOP 3 Bright 
		BURN Q 3 Bright A_PlaySound("misc/bodyhit", CHAN_VOICE)
		BURN RSTU 3 Bright 		
		BURN V -1
		goto Death
	Raise:
		Stop
   } 
}

