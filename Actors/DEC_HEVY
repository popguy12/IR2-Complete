			OGCG BBB 3 A_VileChase
			TNT1 A 0 A_SpawnItem("HeavyHitter_FootStep",0,0,0,0)
			OGCG CCC 3 A_VileChase
			OGCG DDD 3 A_VileChase
			TNT1 A 0 A_SpawnItem("HeavyHitter_FootStep",0,0,0,0)
			goto Chase
	
		missile:
			TNT1 A 0 A_JumpIfCloser(5000, "startfire")
			goto chase
		windup:		
		    TNT1 A 0 A_JumpIfInventory("SuperBadassChainguy_Ammo", 180, "ff_NoAmmo")
		    OGCG E 35 A_PlaySound("minigun/wndup")
		startfire:	
			OGCG EE 4 A_FaceTarget 
			TNT1 A 0 A_JumpIfInventory("SuperBadassChainguy_Ammo", 180, "ff_NoAmmo")
		Shooting:
		    TNT1 A 0 A_JumpIfInventory("SuperBadassChainguy_Ammo", 180, "endfire")
		    OGCG FG 1 bright A_FaceTarget
			TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
			TNT1 A 0 A_FaceTarget 
			TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 34, 9, frandom(-4.0,4.0),CMF_OFFSETPITCH , frandom(-3.0,3.0)) 
			TNT1 A 0 A_SpawnProjectile("E_ARifleCasingSpawner",35,15,0,5,0)
			TNT1 A 0 A_GiveInventory("SuperBadassChainguy_Ammo", 3)
			OGCG FG 1 bright A_FaceTarget
			TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
			TNT1 A 0 A_FaceTarget 
			TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 34, 9, frandom(-4.0,4.0),CMF_OFFSETPITCH , frandom(-3.0,3.0)) 
			TNT1 A 0 A_SpawnProjectile("E_ARifleCasingSpawner",35,15,0,5,0)
			TNT1 A 0 A_GiveInventory("SuperBadassChainguy_Ammo", 3)
			OGCG FG 1 bright A_FaceTarget
			TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
			TNT1 A 0 A_FaceTarget 
			TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 34, 9, frandom(-4.0,4.0),CMF_OFFSETPITCH , frandom(-3.0,3.0)) 
			TNT1 A 0 A_SpawnProjectile("E_ARifleCasingSpawner",35,15,0,5,0)
			TNT1 A 0 A_GiveInventory("SuperBadassChainguy_Ammo", 3)
			OGCG FG 1 bright A_FaceTarget
			TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
			TNT1 A 0 A_FaceTarget 
			TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 34, 9, frandom(-4.0,4.0),CMF_OFFSETPITCH , frandom(-3.0,3.0)) 
			TNT1 A 0 A_SpawnProjectile("E_ARifleCasingSpawner",35,15,0,5,0)
			TNT1 A 0 A_GiveInventory("SuperBadassChainguy_Ammo", 3)
			OGCG FG 1 bright A_FaceTarget
			TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
			TNT1 A 0 A_FaceTarget 
			TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 34, 9, frandom(-4.0,4.0),CMF_OFFSETPITCH , frandom(-3.0,3.0)) 
			TNT1 A 0 A_SpawnProjectile("E_ARifleCasingSpawner",35,15,0,5,0)
			TNT1 A 0 A_GiveInventory("SuperBadassChainguy_Ammo", 3)
			OGCG E 2 A_MonsterRefire(240, "endfire")
			goto shooting	
	    endfire:
			OGCG E 10 A_PlaySound("minigun/wndwn",253,0.88,0,1)
			OGCG E 10
			TNT1 A 0 A_JumpIfInventory("SuperBadassChainguy_Ammo", 360, "ff_NoAmmo")
			goto chase
		ff_NoAmmo:
			OGCG E 1 A_FaceTarget
			OGCG E 1 A_PlaySound("Weapons/TormentorCycle")
			OGCG E 1 A_PlaySound("Weapons/TormentorCycle")
			OGCG E 1 A_PlaySound("Weapons/TormentorCycle")
			OGCG E 1 A_PlaySound("Weapons/TormentorCycle")
			OGCG E 1 A_PlaySound("Weapons/TormentorCycle")
			OGCG E 9
			goto reload_check
		
		//
		reload_check:
			TNT1 A 0 A_JumpIfCloser(1000, "retreat")
		reload:
		    OGCG E 5 A_PlaySound("minigun/open")
			OGCG E 5 A_PlaySound("minigun/load1")
			OGCG E 15 A_PlaySound("minigun/load2")
			OGCG E 5 A_PlaySound("minigun/close")
			TNT1 A 0 A_TakeInventory("SuperBadassChainguy_Ammo", 360)
			TNT1 A 0 A_TakeInventory("SuperBadass_RetreatTimer", 999)
			goto chase	
		retreat:
			TNT1 A 0 A_JumpIfInventory("SuperBadass_RetreatTimer", 5, "Reload")
			OGCG AAA 2 A_Wander
			OGCG BBB 2 A_Wander
			TNT1 A 0 A_SpawnItem("HeavyHitter_FootStep",0,0,0,0)
			OGCG CCC 2 A_Wander
			OGCG DDD 2 A_Wander
			TNT1 A 0 A_SpawnItem("HeavyHitter_FootStep",0,0,0,0)
			TNT1 A 0 A_GiveInventory("SuperBadass_RetreatTimer", 1)
			loop
				//
		pain:
			OGCG H 2 
			OGCG H 2 A_Pain
			goto chase
		Pain.Fire:
			OGCG A 0 A_PlaySound("Tyrant/Pain")
			OGCG A 0 A_SpawnItemEx("FlameTrails",0,0,32)
			OGCG A 0 A_Recoil(-8)
			OGCG A 0 A_SpawnItemEx("Heavy_Ember",0,0,32)
			OGCG AAAA 1 A_SetAngle(12 + angle)
			OGCG A 1 A_Pain
			OGCG B 0 A_Recoil(-8)
			OGCG A 0 A_SpawnItemEx("SmallFlameTrails",0,0,32)
			OGCG BBBB 1 A_SetAngle(12 + angle)
			OGCG B 1 A_Pain
			OGCG C 0 A_Recoil(-8)
			OGCG A 0 A_SpawnItemEx("FlameTrails",0,0,32)
			OGCG CCCC 1 A_SetAngle(12 + angle)
			OGCG C 1 A_Pain
			OGCG D 0 A_Recoil(-8)
			OGCG DDDD 1 A_SetAngle(12 + angle)
			OGCG D 1 A_Pain
			OGCG A 0 A_SpawnItemEx("FlamethrowerFireParticles",0,0,32)
			OGCG A 0 A_Jump(128,"Pain.Fire")
			goto chase
		
		////
		death:
			TNT1 A 0 A_GiveToTarget("ShitMyPlayerSaysWhenHeKillsShit",1)
			TNT1 A 0 A_GiveToTarget("PlayerScore",1000)
			OGCG I 3 A_Scream
			OGCG J 3 A_NoBlocking
			OGCG K 3
			OGCG L 3 A_NoBlocking
			OGCG M 2
			OGCG N -1 A_BossDeath
			Stop
		Death.PointBlank:
		XDeath:
			TNT1 A 0 A_PlaySound("minigun/wndwn",253,0.88,0,1)
			TNT1 A 0 A_GiveToTarget("ShitMyPlayerSaysWhenHeKillsShit",1)
			TNT1 A 0 A_GiveToTarget("PlayerScore",1000)
			TNT1 A 0 A_NoBlocking
			CNSG M 4
			CNSG N 4 A_XScream
			CNSG O 4 A_NoBlocking
			CNSG PQRST 4
			CNSG U -1
			Stop
		Raise:
			stop
		
	  }

}

