actor HH_CrimsonElite : ChaingunGuy {
	obituary "%o got plowed by a Crimson Elite"
	health 800
	Speed 6
	Decal BlazeChip
	DropItem "ClipBoxReplacer"
    DropItem "ClipBoxReplacer"
    DropItem "ClipBoxReplacer"
    DropItem "ClipBoxReplacer"
	DropItem "HeavyPistolAmmo"
    DropItem "LightPistolAmmo"
	DropItem "HeavyPistolAmmo"
    DropItem "LightPistolAmmo"
	BloodColor "7F0000"
	PainChance 64
	Scale 1.085
	Tag "\cgCrimson Elite Chaingunner"
	SeeSound "Tyrant/See"
    PainSound "Tyrant/Pain"
    DeathSound "Tyrant/Death"
    ActiveSound "Tyrant/Active"
	GibHealth 300
	DamageFactor "PistolBullet", 0.88
	DamageFactor "MagnumBullet", 1.111
	DamageFactor "ShotgunPellet", 1.0
	DamageFactor "RifleBullet", 1.333
	DamageFactor "PDWBullet", 1.0
	DamageFactor "HACBullet", 1.666
	DamageFactor "Gauss", 1.666
	+BOSS
	+MISSILEMORE
	+QUICKTORETALIATE
	-Pushable
	+IsMonster
	states{
		spawn:
			MP2S AAA 3 A_Wander
			TNT1 A 0 A_Look
			MP2S BBB 3 A_Wander
			TNT1 A 0 A_Look
			TNT1 A 0 A_SpawnItem("HeavyHitter_FootStep",0,0,0,0)
			MP2S CCC 3 A_Wander
			TNT1 A 0 A_Look
			MP2S DDD 3 A_Wander
			TNT1 A 0 A_Look
			TNT1 A 0 A_SpawnItem("HeavyHitter_FootStep",0,0,0,0)
			TNT1 A 0 A_GiveInventory("BadassChainguy_MustWindup", 1)
			loop
			
		//			
		see:
			TNT1 A 0 A_TakeInventory("PathClear",1)
			TNT1 A 0 A_TakeInventory("CeilingClear",1)
		Chase:
			MP2S AAA 3 A_VileChase
			MP2S BBB 3 A_VileChase
			TNT1 A 0 A_SpawnItem("HeavyHitter_FootStep",0,0,0,0)
			MP2S CCC 3 A_VileChase
			MP2S DDD 3 A_VileChase
			TNT1 A 0 A_SpawnItem("HeavyHitter_FootStep",0,0,0,0)
			goto Chase
	
		missile:
			TNT1 A 0 A_JumpIfCloser(5000, "startfire")
			goto chase
		windup:		
		    TNT1 A 0 A_JumpIfInventory("BadassChainguy_Ammo", 180, "ff_NoAmmo")
		    MP2S E 35 A_PlaySound("minigun/wndup")
			TNT1 A 0 A_TakeInventory("BadassChainguy_MustWindup", 1)
		startfire:	
			MP2S AA 4 A_FaceTarget 
			TNT1 A 0 A_JumpIfInventory("BadassChainguy_Ammo", 180, "ff_NoAmmo")
			TNT1 A 0 A_JumpIfInventory("BadassChainguy_MustWindup", 1, "windup")
		Shooting:
		    TNT1 A 0 A_JumpIfInventory("BadassChainguy_Ammo", 180, "endfire")
		    MP2S FG 1 bright A_FaceTarget
			TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
			TNT1 A 0 A_FaceTarget 
			TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 34, 9, frandom(-4.0,4.0),CMF_OFFSETPITCH , frandom(-3.0,3.0)) 
			TNT1 A 0 A_SpawnProjectile("E_ARifleCasingSpawner",35,15,0,5,0)
			TNT1 A 0 A_GiveInventory("BadassChainguy_Ammo", 1)
			MP2S FG 1 bright A_FaceTarget
			TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
			TNT1 A 0 A_FaceTarget 
			TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 34, 9, frandom(-4.0,4.0),CMF_OFFSETPITCH , frandom(-3.0,3.0)) 
			TNT1 A 0 A_SpawnProjectile("E_ARifleCasingSpawner",35,15,0,5,0)
			TNT1 A 0 A_GiveInventory("BadassChainguy_Ammo", 1)
			MP2S FG 1 bright A_FaceTarget
			TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
			TNT1 A 0 A_FaceTarget 
			TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 34, 9, frandom(-4.0,4.0),CMF_OFFSETPITCH , frandom(-3.0,3.0)) 
			TNT1 A 0 A_SpawnProjectile("E_ARifleCasingSpawner",35,15,0,5,0)
			TNT1 A 0 A_GiveInventory("BadassChainguy_Ammo", 1)
			MP2S FG 1 bright A_FaceTarget
			TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
			TNT1 A 0 A_FaceTarget 
			TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 34, 9, frandom(-4.0,4.0),CMF_OFFSETPITCH , frandom(-3.0,3.0)) 
			TNT1 A 0 A_SpawnProjectile("E_ARifleCasingSpawner",35,15,0,5,0)
			TNT1 A 0 A_GiveInventory("BadassChainguy_Ammo", 1)
			MP2S FG 1 bright A_FaceTarget
			TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
			TNT1 A 0 A_FaceTarget 
			TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 34, 9, frandom(-4.0,4.0),CMF_OFFSETPITCH , frandom(-3.0,3.0)) 
			TNT1 A 0 A_SpawnProjectile("E_ARifleCasingSpawner",35,15,0,5,0)
			TNT1 A 0 A_GiveInventory("BadassChainguy_Ammo", 1)
			MP2S E 2 A_MonsterRefire(200, "endfire")
			goto shooting	
	    endfire:
			MP2S E 10 A_PlaySound("minigun/wndwn",253,0.88,0,1)
			MP2S E 10
			TNT1 A 0 A_GiveInventory("BadassChainguy_MustWindup", 1)
			TNT1 A 0 A_JumpIfInventory("BadassChainguy_Ammo", 180, "ff_NoAmmo")
			goto chase
		ff_NoAmmo:
			MP2S E 1 A_FaceTarget
			MP2S E 1 A_PlaySound("Weapons/TormentorCycle")
			MP2S E 1 A_PlaySound("Weapons/TormentorCycle")
			MP2S E 1 A_PlaySound("Weapons/TormentorCycle")
			MP2S E 1 A_PlaySound("Weapons/TormentorCycle")
			MP2S E 1 A_PlaySound("Weapons/TormentorCycle")
			MP2S E 9
			goto reload_check
		
		//
		reload_check:
			TNT1 A 0 A_JumpIfCloser(1000, "retreat")
		reload:
		    MP2S E 5 A_PlaySound("minigun/open")
			MP2S E 5 A_PlaySound("minigun/load1")
			MP2S E 15 A_PlaySound("minigun/load2")
			MP2S E 5 A_PlaySound("minigun/close")
			TNT1 A 0 A_TakeInventory("BadassChainguy_Ammo", 300)
			TNT1 A 0 A_TakeInventory("Badass_RetreatTimer", 8)
			goto chase	
		retreat:
			TNT1 A 0 A_JumpIfInventory("Badass_RetreatTimer", 10, "Reload")
			MP2S ABCD 2 A_Wander
			TNT1 A 0 A_GiveInventory("Badass_RetreatTimer", 1)
			loop
				//
		pain:
			MP2S H 2 
			MP2S H 2 A_Pain
			goto chase
		Pain.Fire:
		MP2S A 0 A_PlaySound("Tyrant/Pain")
		MP2S A 0 A_SpawnItemEx("FlameTrails",0,0,32)
		MP2S A 0 A_Recoil(-8)
		MP2S A 0 A_SpawnItemEx("Heavy_Ember",0,0,32)
		MP2S AAAA 1 A_SetAngle(12 + angle)
		MP2S A 1 A_Pain
		MP2S B 0 A_Recoil(-8)
		MP2S A 0 A_SpawnItemEx("SmallFlameTrails",0,0,32)
		MP2S BBBB 1 A_SetAngle(12 + angle)
		MP2S B 1 A_Pain
		MP2S C 0 A_Recoil(-8)
		MP2S A 0 A_SpawnItemEx("FlameTrails",0,0,32)
		MP2S CCCC 1 A_SetAngle(12 + angle)
		MP2S C 1 A_Pain
		MP2S D 0 A_Recoil(-8)
		MP2S DDDD 1 A_SetAngle(12 + angle)
		MP2S D 1 A_Pain
		MP2S A 0 A_SpawnItemEx("FlamethrowerFireParticles",0,0,32)
		MP2S A 0 A_Jump(128,"Pain.Fire")
		goto chase
		
		////
		death:
		TNT1 A 0 A_GiveToTarget("ShitMyPlayerSaysWhenHeKillsShit",1)
		TNT1 A 0 A_GiveToTarget("PlayerScore",500)
		MP2S I 3 A_Scream
		TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
        TNT1 A 0 A_SpawnItem ("E_ARifleCasingSpawner", 0, 30,0)
		TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 32, 15, 0, 2, -20)
		MP2S J 3 BRIGHT A_NoBlocking
		MP2S K 3
		TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
		TNT1 A 0 A_SpawnItem ("E_ARifleCasingSpawner", 0, 30,0)
		TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 32, 15, 0, 2, -20)
		MP2S L 3 BRIGHT A_NoBlocking
		MP2S M 2
		TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
		TNT1 A 0 A_SpawnItem ("E_ARifleCasingSpawner", 0, 30,0)
		TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 24, 15, -20, 2, -20)
		MP2S N 2 BRIGHT
		MP2S O 2
		TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
		TNT1 A 0 A_SpawnItem ("E_ARifleCasingSpawner", 0, 30,0)
		TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 24, 15, -20, 2, -20)
		MP2S P 2 BRIGHT
		MP2S Q 2
		TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
		TNT1 A 0 A_SpawnItem ("E_ARifleCasingSpawner", 0, 30,0)
		TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 24, 15, -20, 2, 20)
		MP2S R 2 BRIGHT
		MP2S S 2
		TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
		TNT1 A 0 A_SpawnItem ("E_ARifleCasingSpawner", 0, 30,0)
		TNT1 A 0 A_SpawnProjectile ("e_arifle_tracer", 24, 15, -10, 2, 40)
		MP2S T 2 BRIGHT
		MP2S U 2
		TNT1 A 0 A_PlaySound("minigun/shoot",253,0.88,0,1)
		TNT1 A 0 A_SpawnItem ("E_ARifleCasingSpawner", 0, 30,0)
		MP2S V 2 BRIGHT
		MP2S W 2
		TNT1 A 0 A_PlaySound("minigun/wndwn",253,0.88,0,1)
		MP2S W -1 A_BossDeath
		Stop
  Death.PointBlank:
  XDeath:
		TNT1 A 0 A_PlaySound("minigun/wndwn",253,0.88,0,1)
		TNT1 A 0 A_GiveToTarget("ShitMyPlayerSaysWhenHeKillsShit",1)
	  TNT1 A 0 A_GiveToTarget("PlayerScore",1000)
	  TNT1 A 0 A_NoBlocking
	  CNSG M 4
	  CNSG N 4 A_XScream
      CNSG O 4 A_NoBlocking
      CNSG PQRST 4
	  CNSG U -1
      Stop
    Raise:
		stop
		
	  }

}

