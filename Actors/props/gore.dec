ACTOR FlyingImpHeadBoom
{
	Radius 4
	Height 4
	Health 32767
	Speed 0
	Mass 9
	Gravity 0.5
	BounceCount 4
	BounceFactor 0.75
	SeeSound "FleshImpact"
	Bloodcolor "7F0000"
	+SHOOTABLE
	+HEXENBOUNCE
	+MISSILE
	+NOTELEPORT
	+DONTSPLASH
	+NOBLOCKMAP
 	+NOBLOCKMONST
 	+FORCEXYBILLBOARD
	-NOGRAVITY
	-ACTIVATEPCROSS
    -ACTIVATEIMPACT
    Decal BloodSplat
	States
	{
	Spawn:
		IHED A 4
		Loop
	Death:
		IHED M 35
		goto Fade
	Fade:
	Death:
	Boom:
		IHED A 0
		IHED A 0 A_Explode(64, 64)
		TNT1 A 0 A_PlaySound("sfx/sboom1",CHAN_AUTO)
		IHED A 0 A_PlaySound("misc/gibbed", CHAN_AUTO)
		TNT1 A 1 A_SpawnItemEx("gshot_impactspawner",0,0,0,0,0,0)
		IHED AAAAAA 0 A_SpawnItemEx("Blood", 0, 0, 0, random(-4,4), random(-4,4), random(4, 16), random(-180,180), SXF_CLIENTSIDE, 0)
		TNT1 AA 1
		stop
	}
}

ACTOR FlyingImpHeadNYC
{
	Radius 4
	Height 4
	Health 32767
	Speed 0
	Mass 9
	Gravity 0.5
	BounceCount 4
	BounceFactor 0.75
	SeeSound "FleshImpact"
	Bloodcolor "7F0000"
	+SHOOTABLE
	+HEXENBOUNCE
	+MISSILE
	+NOTELEPORT
	+DONTSPLASH
	+NOBLOCKMAP
 	+NOBLOCKMONST
 	+FORCEXYBILLBOARD
	-NOGRAVITY
	-ACTIVATEPCROSS
    -ACTIVATEIMPACT
    Decal BloodSplat
	States
	{
	Spawn:
		IHED A 4
		loop
	Death:
		IHED M 30
		goto JumpUp
	JumpUp:
		IHED B 0 A_ChangeFlag("NOGRAVITY", 1)
		IHED B 0 A_ChangeFlag("FLOATBOB", 1)
		IHED B 0 A_ChangeFlag("MISSILE", 0)
		IHED B 0 A_ChangeFlag("HEXENBOUNCE", 0)
		IHED B 0 ThrustThingZ(0, 12, 0, 0)
		goto Yeah
	Yeah:
		IHED A 0
		IHED A 0 A_PlaySound("NYC", CHAN_AUTO)
		IHED ABABABABABAB 1
		IHED A 0 A_Stop
		IHED ABABABABABABABABABABABABABAB 1
		IHED ABABABABAB 2
		IHED CBABCB 2
		goto Drop1
	Drop1:
		IHED N 0 A_ChangeFlag("NOGRAVITY", 0)
		IHED N 0 A_ChangeFlag("FLOATBOB", 0)
		IHED N 0 A_ChangeFlag("LOWGRAVITY", 1)
		IHED N 20
		goto NewYorkCity
	NewYorkCity:
		IHED A 0 A_ChangeFlag("NOGRAVITY", 1)
		IHED A 0 A_ChangeFlag("FLOATBOB", 1)
		IHED A 0 ThrustThingZ(0, 7, 0, 0)
		IHED ABABABCDABAB 1
		IHED A 0 A_Stop
		IHED ABCDABABABABABABABABABABABABABCDABABABABABACBDABABABABCDABABABABABABABABABABABCDABCDABABABABABCD 1
		goto Drop2
	Drop2:
		IHED O 0 A_ChangeFlag("NOGRAVITY", 0)
		IHED O 0 A_ChangeFlag("FLOATBOB", 0)
		IHED O 0 A_ChangeFlag("LOWGRAVITY", 1)
		IHED O 27
		goto AHAHA
	AHAHA:
		IHED A 0 A_ChangeFlag("NOGRAVITY", 1)
		IHED A 0 A_ChangeFlag("FLOATBOB", 1)
		IHED A 0 ThrustThingZ(0, 12, 0, 0)
		IHED ABABABCDABAB 1
		IHED A 0 A_Stop
		IHED ABABEFGHIJKLEFGHIJKLEFGHIJKLEFGHIJKLEFGHIJKLEFGHIJKLEFGHIJKLEFGHIJKLEFGHIJKLEFGHIJKL 1
		goto Boom
	Boom:
		IHED A 0
		IHED A 0 A_Explode(64, 64)
		TNT1 A 0 A_PlaySound("sfx/sboom1",CHAN_AUTO)
		IHED A 0 A_PlaySound("misc/gibbed", CHAN_AUTO)
		TNT1 A 1 A_SpawnItemEx("gshot_impactspawner",0,0,0,0,0,0)
		IHED AAAAAA 0 A_SpawnItemEx("Blood", 0, 0, 0, random(-4,4), random(-4,4), random(4, 16), random(-180,180), SXF_CLIENTSIDE, 0)
		TNT1 AA 1
		stop
	}
}