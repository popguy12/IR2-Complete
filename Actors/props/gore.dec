/*
----------------------------
MetaDoom Stuff by Kinsie, Edited by TiberiumSoul
Actor Definitions
Gore Props
----------------------------
*/

ACTOR TiberCrushedProp replaces Gibs
{
	States
	{
	Spawn:
		POL5 A 0
		POL5 A 0 A_Jump(128,2)
		POL5 A 0 A_SetScale(-1,1)
	End:
		POL5 A -1
		Stop
	}
}

ACTOR TiberBrainStem replaces BrainStem
{
	States
	{
	Spawn:
		BRS1 A 0
		BRS1 A 0 A_Jump(128,2)
		BRS1 A 0 A_SetScale(-1,1)
	End:
		BRS1 A -1
		Stop
	}
}

ACTOR TiberColonGibs replaces ColonGibs
{
	States
	{
	Spawn:
		POB1 A 0
		POB1 A 0 A_Jump(128,2)
		POB1 A 0 A_SetScale(-1,1)
	End:
