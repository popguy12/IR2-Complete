}

ACTOR TiberSmallBloodPool replaces SmallBloodPool
{
	States
	{
	Spawn:
		TNT1 A 0 
		TNT1 A 0 
		Stop
	}
}

//bloody twitch
ACTOR TiberBloodyTwitch replaces BloodyTwitch
{
	Radius 16
	Height 68
  	Health 300
	DeathHeight 68
	ProjectilePassHeight -16
	Bloodcolor "7F0000"
	+SOLID
	+NOTAUTOAIMED
	+DONTTHRUST
	+SHOOTABLE
	+DONTGIB
	+RANDOMIZE
	+NOICEDEATH
	+NOGRAVITY
	+SPAWNCEILING
	+DONTFALL
	States
	{
	Spawn:
		GOR1 A 10
		GOR1 B 15
		GOR1 C 8
		GOR1 B 6
		Loop
	Death:
		GOR1 D 0 A_NoGravity
		GOR1 D 0
		{
			A_PlaySound ("misc/gibbed");
			A_SpawnItemEx ("NashGoreGibs",0,0,0,frandom(-6,6),frandom(-6,6),frandom(-3,9),0,SXF_TRANSFERTRANSLATION|SXF_ABSOLUTEPOSITION|SXF_ABSOLUTEANGLE|SXF_ABSOLUTEVELOCITY|SXF_NOCHECKPOSITION|SXF_TRANSFERPOINTERS|SXF_CLIENTSIDE);
			A_SpawnItemEx ("NashGoreGibs",0,0,0,frandom(-6,6),frandom(-6,6),frandom(-3,9),0,SXF_TRANSFERTRANSLATION|SXF_ABSOLUTEPOSITION|SXF_ABSOLUTEANGLE|SXF_ABSOLUTEVELOCITY|SXF_NOCHECKPOSITION|SXF_TRANSFERPOINTERS|SXF_CLIENTSIDE);
			A_SpawnItemEx ("NashGoreGibs",0,0,0,frandom(-6,6),frandom(-6,6),frandom(-3,9),0,SXF_TRANSFERTRANSLATION|SXF_ABSOLUTEPOSITION|SXF_ABSOLUTEANGLE|SXF_ABSOLUTEVELOCITY|SXF_NOCHECKPOSITION|SXF_TRANSFERPOINTERS|SXF_CLIENTSIDE);
			A_SpawnItemEx ("NashGoreGibs",0,0,0,frandom(-6,6),frandom(-6,6),frandom(-3,9),0,SXF_TRANSFERTRANSLATION|SXF_ABSOLUTEPOSITION|SXF_ABSOLUTEANGLE|SXF_ABSOLUTEVELOCITY|SXF_NOCHECKPOSITION|SXF_TRANSFERPOINTERS|SXF_CLIENTSIDE);
			A_SpawnItemEx ("NashGoreGibs",0,0,0,frandom(-6,6),frandom(-6,6),frandom(-3,9),0,SXF_TRANSFERTRANSLATION|SXF_ABSOLUTEPOSITION|SXF_ABSOLUTEANGLE|SXF_ABSOLUTEVELOCITY|SXF_NOCHECKPOSITION|SXF_TRANSFERPOINTERS|SXF_CLIENTSIDE);
			A_SpawnItemEx ("NashGoreGibs",0,0,0,frandom(-6,6),frandom(-6,6),frandom(-3,9),0,SXF_TRANSFERTRANSLATION|SXF_ABSOLUTEPOSITION|SXF_ABSOLUTEANGLE|SXF_ABSOLUTEVELOCITY|SXF_NOCHECKPOSITION|SXF_TRANSFERPOINTERS|SXF_CLIENTSIDE);
			A_SpawnItemEx ("NashGoreGibs",0,0,0,frandom(-6,6),frandom(-6,6),frandom(-3,9),0,SXF_TRANSFERTRANSLATION|SXF_ABSOLUTEPOSITION|SXF_ABSOLUTEANGLE|SXF_ABSOLUTEVELOCITY|SXF_NOCHECKPOSITION|SXF_TRANSFERPOINTERS|SXF_CLIENTSIDE);
			A_SpawnItemEx ("NashGoreGibs",0,0,0,frandom(-6,6),frandom(-6,6),frandom(-3,9),0,SXF_TRANSFERTRANSLATION|SXF_ABSOLUTEPOSITION|SXF_ABSOLUTEANGLE|SXF_ABSOLUTEVELOCITY|SXF_NOCHECKPOSITION|SXF_TRANSFERPOINTERS|SXF_CLIENTSIDE);
			A_ChangeFlag("NOBLOOD",true);
		}
		GOR1 D -1
		stop
	}
}

ACTOR TiberNonsolidTwitch replaces NonsolidTwitch
{
	Radius 20
	Height 68
	-SOLID
	+NOGRAVITY
	+SPAWNCEILING
	States
	{
	Spawn:
		GOR1 D 0
		GOR1 D -1
		wait
	}
}

