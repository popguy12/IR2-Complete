// treeses

ACTOR TiberBigTree replaces BigTree
{
	Radius 32
	Height 108
	ProjectilePassHeight -16
	Health 250
	DeathHeight 108
	ProjectilePassHeight -16
	BloodType "NullBloodHell"
	+SOLID
	+NOTAUTOAIMED
	+DONTTHRUST
	+SHOOTABLE
	+DONTGIB
	+RANDOMIZE
	+NOICEDEATH
	+NOBLOODDECALS
	PainChance 255
	DamageFactor "Normal", 0.33
	DamageFactor "Pistolbullet", 0.33
	DamageFactor "MagnumBullet", 0.33
	DamageFactor "ShotgunPellet", 0.33
	DamageFactor "RifleBullet", 0.33
	DamageFactor "SniperBullet", 0.33
	DamageFactor "CannonBullet", 0.33
	States
	{
	Spawn:
		TRE2 A -1
		Stop
	Pain:
		TRE2 A 0
		TRE2 A 0
		{
			A_PlaySound("props/wood/pain");
			A_CustomMissile ("TiberGibWood", random(32,108), 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibWood", random(32,108), 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibWood", random(32,108), 2, random(0,360), 2, 6);
		}
		goto Spawn		
	Death:
		TRE2 B 0 A_RemoveChildren(true,RMVF_MISC)
		TRE2 B 0 A_PlaySound("props/wood/die1")
		TRE2 B 1 
		{
			A_CustomMissile ("TiberGibBigWood", random(32,108), 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibBigWood", random(32,108), 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibBigWood", random(32,108), 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibBigWood", random(32,108), 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibBigWood", random(32,108), 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibWood", random(32,108), 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibWood", random(32,108), 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibWood", random(32,108), 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibWood", random(32,108), 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibWood", random(32,108), 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibWood", random(32,108), 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibWood", random(32,108), 2, random(0,360), 2, 6);
		}
		TRE2 B -1
		stop
	}
}

actor TiberGibWood
{
	+DOOMBOUNCE
	PROJECTILE
	-NOGRAVITY
	//-NOBLOCKMAP
	-ACTIVATEIMPACT
	+NOTELEPORT
	-TELESTOMP
	-SOLID
	+ROLLSPRITE
	+ROLLCENTER
	Radius 1
	height 1
	Damage 0
	bouncefactor 0.5
	SeeSound "props/wood/gib"
	gravity 0.5
	Speed 5
	States
	{
	Spawn:
		WOOD A 0
		WOOD A 0 A_SetScale(frandom(0.5, 2.0))
		WOOD ABCD 0 A_Jump(128, "Setup")
		goto Setup
	Setup:
		"####" # 0 ThrustThingZ (0, random(32,45), 0, 1)
		"####" # 0 ThrustThing(random(0,360), 8, 1, 0)
	ChangeDir:
		"####" # 0 A_Jump(128,"Alt") 
		goto See
	See:
		"####" # 0 ThrustThingZ(0,6,1,1) 
		"####" # 1 A_SetRoll((roll + 5))
		loop
	Alt:
		"####" # 0 ThrustThingZ(0,6,1,1) 
		"####" # 1 A_SetRoll((roll - 5))
		loop
	Bounce.Floor:
		//"####" # 0 A_SpawnItem("BloodSplat")
		goto ChangeDir
	Bounce.Wall:
		goto ChangeDir
	Death:
		"####" # 0 A_ChangeFlag(NOBLOCKMAP, 0)
		"####" # 0 A_ChangeFlag(FLATSPRITE, 1)
		"####" # 0 A_Warp(AAPTR_DEFAULT,0,0,frandom(0.0100000, 0.0199999),0,WARPF_NOCHECKPOSITION|WARPF_TOFLOOR)
		"####" # -1
		Stop
    }
}

actor TiberGibBigWood // and veiny
{
	+DOOMBOUNCE
	PROJECTILE
	-NOGRAVITY
	//-NOBLOCKMAP
	-ACTIVATEIMPACT
	+NOTELEPORT
	-TELESTOMP
