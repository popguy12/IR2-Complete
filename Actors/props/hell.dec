// candles
ACTOR TiberCandelabra replaces Candelabra
{
	health 50
	Radius 16
	Height 60
	DeathHeight 60
	ProjectilePassHeight -16
	BloodType "NullBloodHell"
	+SOLID
	+NOTAUTOAIMED
	+DONTTHRUST
	+SHOOTABLE
	+DONTGIB
	+RANDOMIZE
	+NOICEDEATH
	+NOBLOODDECALS
	DamageFactor "Normal", 0.33
	DamageFactor "Pistolbullet", 0.33
	DamageFactor "MagnumBullet", 0.33
	DamageFactor "ShotgunPellet", 0.33
	DamageFactor "RifleBullet", 0.33
	DamageFactor "SniperBullet", 0.33
	DamageFactor "CannonBullet", 0.33
	States
	{
	Spawn:
		CBRA A 0
		CBRA A 0 A_PlaySoundEx("props/candles/candelabra", "Body", 1)
		goto Idle
	Idle:
		CBRA A -1 Bright
		Loop
	Death:
		CBRA B 0 A_RemoveChildren(true,RMVF_MISC)
		CBRA B 0 A_PlaySound("props/techlamp/break")
		CBRA B 1 
		{
			A_CustomMissile ("TiberGibGlass", 55, 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibGlass", 55, 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibGlass", 55, 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibGlass", 55, 2, random(0,360), 2, 6);
			
			A_CustomMissile ("TiberGibCandle", 55, 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibCandle", 55, 2, random(0,360), 2, 6);
			A_CustomMissile ("TiberGibCandle", 55, 2, random(0,360), 2, 6);
		}
		CBRA B -1
		stop
	}
}

