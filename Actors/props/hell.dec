ACTOR TiberEvilEye replaces EvilEye
{
	Radius 16
	Height 54
	ProjectilePassHeight -16
  	Health 666
	DeathHeight 54
	Bloodcolor "7F0000"
	DamageFactor "Normal", 0.33
	DamageFactor "Pistolbullet", 0.33
	DamageFactor "MagnumBullet", 0.33
	DamageFactor "ShotgunPellet", 0.33
	DamageFactor "RifleBullet", 0.33
	DamageFactor "SniperBullet", 0.33
	DamageFactor "CannonBullet", 0.33
	+SOLID
	+NOTAUTOAIMED
	+DONTTHRUST
	+SHOOTABLE
	+DONTGIB
	+RANDOMIZE
	+NOICEDEATH
	States
	{
	Spawn:
		ZEYE A 0
		ZEYE A 0 A_Look
		ZEYE A 0 A_PlaySoundEx("props/floatingskull","Body",1)
		ZEYE A 0 A_PlaySoundEx("props/candles/candlestick","Voice",1)
		goto Idle
	Idle:
		ZEYE A 0 A_StartSound("Apocalypse/cast",127,CHANF_OVERLAP,0.66,2)
		ZEYE A 0 A_SpawnItem("TiberEvilEyeRadiate",0,36)
		ZEYE A 0 A_Look
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE A 0 A_SpawnItem("TiberEvilEyeRadiate",0,36)
		ZEYE A 0 A_Look
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE A 0 A_SpawnItem("TiberEvilEyeRadiate",0,36)
		ZEYE A 0 A_Look
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE ABCDEF 4 Bright A_FaceTarget
		ZEYE ABCDEF 4 Bright A_FaceTarget
		Loop
	Death:
		CEYE A 0
		CEYE A 0 A_StartSound("brain/pain",127,0,1.0,2)
		CEYE A 0
		{
			A_SpawnItemEx ("Blood",0,0,0,frandom(-6,6),frandom(-6,6),frandom(-3,9),0,SXF_TRANSFERTRANSLATION|SXF_ABSOLUTEPOSITION|SXF_ABSOLUTEANGLE|SXF_ABSOLUTEVELOCITY|SXF_NOCHECKPOSITION|SXF_TRANSFERPOINTERS|SXF_CLIENTSIDE);
			A_SpawnItemEx ("Blood",0,0,0,frandom(-6,6),frandom(-6,6),frandom(-3,9),0,SXF_TRANSFERTRANSLATION|SXF_ABSOLUTEPOSITION|SXF_ABSOLUTEANGLE|SXF_ABSOLUTEVELOCITY|SXF_NOCHECKPOSITION|SXF_TRANSFERPOINTERS|SXF_CLIENTSIDE);
			A_SpawnItemEx ("Blood",0,0,0,frandom(-6,6),frandom(-6,6),frandom(-3,9),0,SXF_TRANSFERTRANSLATION|SXF_ABSOLUTEPOSITION|SXF_ABSOLUTEANGLE|SXF_ABSOLUTEVELOCITY|SXF_NOCHECKPOSITION|SXF_TRANSFERPOINTERS|SXF_CLIENTSIDE);
			A_SpawnItemEx ("Blood",0,0,0,frandom(-6,6),frandom(-6,6),frandom(-3,9),0,SXF_TRANSFERTRANSLATION|SXF_ABSOLUTEPOSITION|SXF_ABSOLUTEANGLE|SXF_ABSOLUTEVELOCITY|SXF_NOCHECKPOSITION|SXF_TRANSFERPOINTERS|SXF_CLIENTSIDE);
			A_SpawnItemEx ("Blood",0,0,0,frandom(-6,6),frandom(-6,6),frandom(-3,9),0,SXF_TRANSFERTRANSLATION|SXF_ABSOLUTEPOSITION|SXF_ABSOLUTEANGLE|SXF_ABSOLUTEVELOCITY|SXF_NOCHECKPOSITION|SXF_TRANSFERPOINTERS|SXF_CLIENTSIDE);
			A_SpawnItemEx ("Blood",0,0,0,frandom(-6,6),frandom(-6,6),frandom(-3,9),0,SXF_TRANSFERTRANSLATION|SXF_ABSOLUTEPOSITION|SXF_ABSOLUTEANGLE|SXF_ABSOLUTEVELOCITY|SXF_NOCHECKPOSITION|SXF_TRANSFERPOINTERS|SXF_CLIENTSIDE);
			A_SpawnItem("IoSTeleportFog",0,18);
			A_ChangeFlag("NOBLOOD",true);
		}
		CEYE ABCDEF 4 Bright
		CEYE ABCDEF 4 Bright
		CEYE ABCDEF 4 Bright
	DeathLooper:
		CEYE ABCDEF 4 Bright
		loop
	}
}

ACTOR TiberEvilEyeRadiate
{
	radius 10
	height 10
	+NOCLIP
	+NOGRAVITY
	+NOBLOCKMAP
	Renderstyle add
	states
	{
		Spawn:
		ZEYE X 0
		ZEYE X 0
	DoTheThing:
		ZEYE XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX 1 BRIGHT
		{
			A_FadeOut(0.025);
			A_SetScale(scaleX + 0.03);
		}
		stop
	}
}

Actor TiberEvilEyeDed
{
	Renderstyle Add
	+NOGRAVITY
	-SOLID
	states
	{
	Spawn:
		TNT1 A 0
		CEYE ABCDEF 4 Bright
		loop
	}
}

