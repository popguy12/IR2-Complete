ACTOR NullBloodHell {}

ACTOR TiberFloatingSkull replaces FloatingSkull
{
	Radius 16
	Height 26
	ProjectilePassHeight -16
	+SOLID
	+FLOATBOB
	+SHOOTABLE
	+DONTTHRUST
	+DONTGIB
	+NOBLOOD
	+NOICEDEATH
	+INVULNERABLE
	States
	{
	Spawn:
		FSKU A 0
		FSKU A 0 A_PlaySoundEx("props/floatingskull", "Body", 1)
		FSKU ABCB 6 Bright
		Loop
	}
}



