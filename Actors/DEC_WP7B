	+BLOODSPLATTER
	+NOEXTREMEDEATH
	+NOTIMEFREEZE
	SeeSound ""
	DeathSound ""
	damagetype Normal
	obituary "%o thought it would be a good idea to try and catch %k's ejected typhoon magazine... that is until %g got %p face caved in."
	States
	{
	Spawn:
		Spawn:
		MISL A 0
		QWOP C 1
		Wait
