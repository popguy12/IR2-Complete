actor BaseEffect
{
  States
  {
  Spawn:
	TNT1 A 0 NoDelay A_JumpIf(GetCVar("ir_perfmode") == 0, "Spawn2")
	TNT1 A 0 A_JumpIf(GetCVar("ir_perfmode") == 1, "ChokerLight")
	TNT1 A 0 A_JumpIf(GetCVar("ir_perfmode") == 2, "ChokerHeavy")
	TNT1 A 0 A_JumpIf(GetCVar("ir_perfmode") == 3, "Vanish")
	 
  ChokerLight:
	TNT1 A 0 A_Jump(256, "Vanish", "Spawn2")
	Goto Spawn2
	
  ChokerHeavy:
	TNT1 A 0 A_Jump(256, "Vanish", "Vanish", "Vanish", "Vanish", "Spawn2")
	Goto Spawn2
	
  Spawn2:
	TNT1 A 1
	Wait
	
  Vanish:
	TNT1 A 0
	Stop
  }
}

