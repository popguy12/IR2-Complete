ACTOR DusterFlare : DusterBasis
{
	States
	{
	Spawn2:
		TNT1 AA 0 A_FadeIn(frandom(0.9,0.99))
		TNT1 A 0 A_SetScale(frandom(0.15,0.2))
		TNT1 A 0 A_Jump(256,"SpriteA","SpriteB","SpriteC","SpriteD")
	SpriteA:
		FLFR A 0
		Goto MolotovVodkail
	SpriteB:
		FLFR B 0
		Goto MolotovVodkail
	SpriteC:
		FLFR C 0
		Goto MolotovVodkail
	SpriteD:
		FLFR D 0
	MolotovVodkail:
