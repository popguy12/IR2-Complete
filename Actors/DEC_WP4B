actor P_ImpalerNail : FastProjectile {
	Height 2
	Radius 2
	PROJECTILE
    +BLOODSPLATTER
	+DONTGIB
	+NOEXTREMEDEATH
	-NOGRAVITY
	//+RIPPER
	DamageType "SSG"
	RenderStyle Normal
	ProjectileKickBack 180
	Speed 150
	Gravity 0.7
	Scale 0.45
	Damage (36+(3*random(1,5)))
	Mass 10
	MissileHeight 3
	MissileType "NewDusterTrailer"
	Decal "HarbingerPrimary"
	states{
		Spawn:
			TNT1 A 0
			NLPJ B 1 BRIGHT
			Goto Fly
		Fly:
			TNT1 A 0
			NLPJ B 1 BRIGHT
			Loop
		Crash:
		Death:
			TNT1 A 0 A_StartSound("SFX/NailRic",178,CHANF_OVERLAP,1.0,1)
			TNT1 A 0 A_SpawnItemEx("HAC_Impact", 0, 0, 0, 0, 0, 0, 0, 0)
			TNT1 A 0 A_SpawnItemEx("HCannonFX_EXP", 0, 0, 0, 0, 0, 0, 0, 0)
			TNT1 A 0 A_Stop()
			NLPJ B 70 BRIGHT
			NLPJ A 4200
			NLPJ AAAAA 1 A_FadeOut(0.2,FTF_REMOVE | FTF_CLAMP)
			Stop
		XDeath:
			TNT1 A 0 A_StopSound(CHAN_BODY)
			NLPJ B 0 A_StartSound("NashGore/bullethitflesh")
			Stop
	}
}

