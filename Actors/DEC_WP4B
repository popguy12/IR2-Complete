ACTOR ImpalerNailgun : IR2Weapon
{
  //$Category IR_Weapons
  //$Title DRK-919 Impaler Nailgun
  //$Sprite 
  Tag "DRK-919 Impaler Nailgun"
  Weapon.SelectionOrder 63
  Weapon.AmmoUse 1
  Weapon.AmmoGive2 2
  Weapon.PreferredSkin "Shotgun"
  //Weapon.UpSound "Weapons/BoneDusterUp"
  Weapon.AmmoType "NailgunLoaded"
  Weapon.AmmoType2 "NailgunReserve"
  IR2Weapon.BulletGraphics "graphics/MikkOS/BigRifleBullet.png", "graphics/MikkOS/BigRifleShell.png"
  decal "BlazeChip"
  Weapon.SlotNumber 4
  Scale 0.55
  weapon.bobstyle smooth
  weapon.bobrangeX 0.4
  weapon.bobrangeY 0.6
  weapon.bobspeed 2.5
  weapon.weaponscalex 1.2
  Inventory.PickupMessage "You got the Drakul Model 919 ''Impaler'' Rotary Nailgun! The Count sends his regards."
  Obituary "%k turned %o into a pincushion with the Impaler."
  +WEAPON.AMMO_OPTIONAL
  +NOAUTOFIRE
  +NOALERT
  +NOAUTOAIM
  +UNDROPPABLE
  States
  {
  Spawn:
    WFRP A -1
    stop
  Ready:
    WFRI A 1 A_WeaponReady(WRF_ALLOWRELOAD)
    loop
  Select:
	TNT1 A 0 A_JumpIfInventory("ImpalerFirstTime",1,"FirstTime")
  Goto SelectNormal
  FirstTime:
	TNT1 A 0 A_StartSound("RW/SLOT4B",251,0,2.0,2)
  SelectNormal:
	TNT1 A 0 A_TakeInventory("ImpalerFirstTime",1)
	TNT1 A 0 A_SetCrosshair(43)
	TNT1 A 1
	WFRS A 1 A_PlaySound("Weapons/CS_Select", CHAN_WEAPON)
	TNT1 A 0 SetPlayerProperty(0,0,2)
	WFRS ABCDEF 1
  SelectLoop:
	WRFI A 1 A_Raise
	Goto SelectLoop
  Deselect:
	TNT1 A 0 A_SetCrosshair(1)
	WFRS F 1 A_PlaySound("Weapons/CS_Deselect", CHAN_WEAPON)
	TNT1 A 0 SetPlayerProperty(0,1,2)
	WFRS FEDCBA 1
	TNT1 A 2 
  DeselectLoop:
	TNT1 A 1 A_Lower
	Goto DeselectLoop
  Fire:
  FireStart:
	WFRI A 0 A_JumpIfInventory("NailgunLoaded",1,1)
    Goto Dryfire
	TNT1 A 0 A_AlertMonsters
    TNT1 A 0 A_StartSound("Weapons/ImpalerWindUp",99,CHANF_DEFAULT,1.0,2)
	WFRI AAABBCD 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WFRI ABCD 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
    Goto FireLoop
  FireLoop:
	TNT1 A 0 A_JumpIfInventory("NailgunLoaded",1,1)
    Goto FireStop
	TNT1 A 0 A_AlertMonsters
	TNT1 A 0 A_SetPitch(pitch - 0.25)
    TNT1 A 0 A_StartSound("Weapons/ImpalerFireLoop",99,CHANF_LOOPING,1.0,2)
	TNT1 A 0 A_StartSound("Weapons/ImpalerAdditive",77,0,0.77,2)
	TNT1 A 0 A_StartSound("Weapons/ImpalerPunch",88,0,0.88,2)
	TNT1 A 0 A_SpawnItem("LightProjectile1",0,0,0,0)
	TNT1 A 0 A_Overlay(-3, "GunFlash")
	TNT1 A 0 A_FireProjectile("ngcasing_spawner",0,0,1,-4,0)
	TNT1 A 0 A_FireProjectile("P_ImpalerNail", frandom(-1, 1), 0, 7, 4, 0,frandom(-1, 1))
	WFRF AB 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
    WFRF CC 1 Bright A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
  FireLooplet:
	TNT1 A 0 A_JumpIfInventory("NailgunLoaded",1,1)
    Goto FireStop
	TNT1 A 0 A_AlertMonsters
	TNT1 A 0 A_SetPitch(pitch - 0.25)
	TNT1 A 0 A_StartSound("Weapons/ImpalerAdditive",77,0,0.77,2)
	TNT1 A 0 A_StartSound("Weapons/ImpalerPunch",88,0,0.88,2)
	TNT1 A 0 A_SpawnItem("LightProjectile1",0,0,0,0)
	TNT1 A 0 A_Overlay(-3, "GunFlash")
	TNT1 A 0 A_FireProjectile("ngcasing_spawner",0,0,1,-4,0)
	TNT1 A 0 A_FireProjectile("P_ImpalerNail", frandom(-1, 1), 0, 7, 4, 0,frandom(-1, 1))
	WFRF DE 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WFRF FF 1 Bright A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_JumpIfInventory("NailgunLoaded",1,1)
    Goto FireStop
	TNT1 A 0 A_AlertMonsters
	TNT1 A 0 A_SetPitch(pitch - 0.25)
	TNT1 A 0 A_StartSound("Weapons/ImpalerAdditive",77,0,0.77,2)
	TNT1 A 0 A_StartSound("Weapons/ImpalerPunch",88,0,0.88,2)
	TNT1 A 0 A_SpawnItem("LightProjectile1",0,0,0,0)
	TNT1 A 0 A_Overlay(-3, "GunFlash")
	TNT1 A 0 A_FireProjectile("ngcasing_spawner",0,0,1,-4,0)
	TNT1 A 0 A_FireProjectile("P_ImpalerNail", frandom(-1, 1), 1, 7, 4, 0,frandom(-1, 1))
	WFRF GH 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WFRF II 1 Bright A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_JumpIfInventory("NailgunLoaded",1,1)
    Goto FireStop
	TNT1 A 0 A_AlertMonsters
	TNT1 A 0 A_SetPitch(pitch - 0.25)
	TNT1 A 0 A_StartSound("Weapons/ImpalerAdditive",77,0,0.77,2)
	TNT1 A 0 A_StartSound("Weapons/ImpalerPunch",88,0,0.88,2)
	TNT1 A 0 A_SpawnItem("LightProjectile1",0,0,0,0)
	TNT1 A 0 A_Overlay(-3, "GunFlash")
	TNT1 A 0 A_FireProjectile("ngcasing_spawner",0,0,1,-4,0)
	TNT1 A 0 A_FireProjectile("P_ImpalerNail", frandom(-1, 1), 0, 7, 4, 0,frandom(-1, 1))
	WFRF JK 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WFRF LL 1 Bright A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_JumpIfInventory("NailgunLoaded",1,1)
    Goto FireStop
	TNT1 A 0 A_AlertMonsters
	TNT1 A 0 A_SetPitch(pitch - 0.25)
	TNT1 A 0 A_StartSound("Weapons/ImpalerAdditive",77,0,0.77,2)
	TNT1 A 0 A_StartSound("Weapons/ImpalerPunch",88,0,0.88,2)
	TNT1 A 0 A_SpawnItem("LightProjectile1",0,0,0,0)
	TNT1 A 0 A_Overlay(-3, "GunFlash")
	TNT1 A 0 A_FireProjectile("ngcasing_spawner",0,0,1,-4,0)
	TNT1 A 0 A_FireProjectile("P_ImpalerNail", frandom(-1, 1), 1, 7, 4, 0,frandom(-1, 1))
	WFRF MN 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WFRF OO 1 Bright A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	QSGG A 0 A_Refire("FireLooplet")
    Goto FireStop
  FireStop:
    TNT1 A 0 A_StartSound("Weapons/ImpalerWindDn",99,CHANF_DEFAULT,1.0,2)
	WFRD ABCD 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WFRI ABCDABCCDDD 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WFRI A 5 A_WeaponReady(WRF_NOFIRE)
    Goto Ready
  DryFire:
	WFRI A 0 A_PlaySound("Weapons/ImpalerReloadSt",199,2.0,0,1) // Play the clicky noise.
	WFRI A 1 A_WeaponReady(WRF_NOFIRE)
	WFRD ABCD 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WFRI A 5 A_WeaponReady(WRF_NOFIRE)
	Goto Ready
  Reload:
	TNT1 A 0 A_JumpIfInventory("NailgunLoaded",40,"Ready")
    TNT1 A 0 A_JumpIfInventory("NailgunReserve",1,1)
    Goto DryFire
  ReloadBegin:
	TNT1 A 0 A_StartSound("Weapons/ImpalerReloadSt",100,0,2.0,2)
    WFRR ABCDEF 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WSRL ABCDE 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WSRL F 6 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WSRL GHIJK 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WSRL L 6 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WSRL L 0 A_StartSound("Weapons/HarbingerSequence3",101,0,1.0,2)
	WSRL L 2 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WSRL T 3 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WSRL NOPQR 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WSRL S 16 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_SpawnItemEx("HarbingerBoxDrop",0,0,5)
	WSRL RQPO 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WSRL N 2 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WSRL M 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WSRL N 0 A_StartSound("Weapons/HarbingerSequence5",102,0,1.0,2)
	WSRL U 2 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WSRL VWXYZ 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WSRL L 2 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WSRL KJIHG 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WSRL F 3 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
  ReloadWork:
    TNT1 A 0 A_JumpIfInventory("NailgunReserve",1,1)
	Goto EndReloading
	TNT1 A 0 A_TakeInventory("NailgunReserve", 1)
    TNT1 A 0 A_GiveInventory("NailgunLoaded", 40)
	TNT1 A 0 A_JumpIfInventory("NailgunLoaded",40,"EndReloading")
	Loop
  EndReloading:
	WSRL N 0 A_StartSound("Weapons/HarbingerSequence6",101,0,1.0,2)
	WSRL EDCBA 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_StartSound("Weapons/ImpalerReloadEd",100,0,2.0,2)
	WFRR FEDCBA 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WFRI ABCDABCCDDD 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	WFRI A 5 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	Goto Ready
  GunFlash:
		TNT1 A 0 A_OverlayFlags(-3, PSPF_ALPHA|PSPF_RENDERSTYLE, true)
		TNT1 A 0 A_OverlayRenderstyle(-3, STYLE_Add)
		TNT1 A 0 A_OverlayAlpha(-3, 0.6)
		TNT1 A 1 Bright 
			{
			A_FireProjectile("HCannonFX", 0, 0, 10, -9, FPF_NOAUTOAIM);
			}
		TNT1 A 0 A_OverlayAlpha(-3, 9.0)
		TNT1 A 1 Bright
		Stop
	}
}

ACTOR ImpalerFirstTime : Inventory {Inventory.MaxAmount 1 Inventory.InterHubAmount 1}

ACTOR NailgunLoaded : Ammo
{
  Inventory.PickupMessage "You shouldn't see this!"
  Inventory.Amount 0
  Inventory.MaxAmount 40
  Ammo.BackpackAmount 0
  Ammo.BackpackMaxAmount 40
  States
  {
  Spawn:
    TNT1 A -1
    Stop
  }
}

ACTOR NailgunReserve : Ammo
{
	Inventory.PickupMessage ""
	Inventory.Amount 1
	Inventory.MaxAmount 3
	Ammo.BackpackAmount 2
	Ammo.BackpackMaxAmount 6
	+UNDROPPABLE
	States
	{
	Spawn:
		TNT1 A -1
		Stop
	}
}

ACTOR NailgunBox : NailgunReserve 27173
{
  Game Doom
  ConversationID 502
  Inventory.PickupMessage "Picked up a box of Drakul 15mm Nails."
  Inventory.PickupSound "items/shellbox"
  Tag "Box of Drakul 15mm Nails"
  Inventory.Amount 1
  +INVENTORY.UNCLEARABLE
  scale 0.22
  States
  {
  Spawn:
    BNAL A -1
    Stop
  }
}


