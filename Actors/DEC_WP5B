ACTOR PDW_Casing
{
   Radius 2
   Height 4
   Speed 8
   Scale 0.08
   BounceSound "Weapons/PistolCasing"
   PROJECTILE
   -NOGRAVITY
   +BOUNCEONACTORS
   +BOUNCEONCEILINGS
   +DONTSPLASH
   +CLIENTSIDEONLY
   Gravity 0.75
   BounceType Doom
   BounceCount 6
   BounceFactor 0.6
   DamageType Nope
   States
   {
   Spawn:
	  ARBC A 0
      HSTC ABCDEFG 1
      Goto Roflcopter
   Roflcopter:
      ARBC A 0 A_Jump(128,1,3,5,7)
      HSTC ABCDEFG 1
      Loop
   Death:
      ARBC A 0 A_SpawnItemEx("PDW_Casing_Liedown")
      stop
   }
}

actor PDW_Casing_Liedown
{
	-NOGRAVITY
    Scale 0.077
	States
	{
	Spawn:
	  TNT1 A 0
	  TNT1 A 0 A_Jump(255,"Spawn1","Spawn2","Spawn3")
	  stop
	Spawn1:
	  HSTC C 1
	  Goto Ded
	Spawn2:
	  HSTC D 1
	  Goto Ded
	Spawn3:
	  HSTC G 1
	  Goto Ded
	Ded:
	  "####" "#" 210 A_CheckSight("Fadying")
	  Loop
	Fadying:
	  "####" "#" 1 A_FadeOut(0.1)
	  Wait
   }
}

