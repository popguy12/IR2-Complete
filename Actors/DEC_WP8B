		{
		A_FireProjectile("p_hcannon_tracer_exp", frandom(-0, 0), 0, 5,5, 0,frandom(-0, 0));
		A_FireProjectile("HCannon_ExpCasingSpawner", -5, 0, 0, 0);
		}
	  else
		{
		A_FireProjectile("P_HCannon_Tracer", frandom(-0, 0), 0, 5,5, 0,frandom(-0, 0));
		A_FireProjectile("HCannon_CasingSpawner", -5, 0, 0, 0);
		}
	  A_WeaponOffset(frandom(-3, 3), 32+frandom(-3, 3), WOF_INTERPOLATE);
	  A_Quake(2, 5, 0, 16);
	  A_TakeInventory("HarbingerFeed",1,TIF_NOTAKEINFINITE);
	  }
	  TNT1 AAA 0 A_FireProjectile("gausssmoke_spawner2",0,0,0,4,0)		
