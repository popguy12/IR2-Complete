   CannonFireStuff:
	  TNT1 A 0
      {
	  A_AlertMonsters;
	  A_SetPitch(pitch - 2.5);
	  A_StartSound("Weapons/HarbingerPunchLayer",77,0,0.77,2);
	  A_StartSound("Weapons/HarbingerFirePrimary",99,0,0.99,2);
	  A_StartSound("Weapons/HarbingerFireAdditive",88,0,0.88,2);
	  A_SpawnItem("LightProjectile1",0,0,0,0);
	  A_Overlay(-3, "Flashpicker");
	  
