	  TNT1 A 0 A_JumpIfInventory("HarbingerAltAmmo", 1, 2)
	  HMNG A 0 A_Jump(256, 2)
	  XMNG A 0
	  "####" BBBCCD 1
//	  "####" BBBCCDABCDABCD 1
//	  MNGZ EFGH 1	(idk what this is)
	  TNT1 A 0
	  {
		  if(CountInv("HarbingerFeed") > 0)
		  {
			if(CountInv("HarbingerHeatToken") > 105)
			{
			A_PlaySound("Weapons/HarbingerHeat4", 6, 1, 0, 2);
			}
			else if(CountInv("HarbingerHeatToken") > 70)
			{
			A_PlaySound("Weapons/HarbingerHeat3", 6, 1, 0, 2);
			}
			else if(CountInv("HarbingerHeatToken") > 35)
			{
			A_PlaySound("Weapons/HarbingerHeat2", 6, 1, 0, 2);
			}
			else
			{
			A_PlaySound("Weapons/HarbingerHeat1", 6, 1, 0, 2);
			}
		  }
	  }
      TNT1 A 0 A_JumpIfInventory("HarbingerFeed", 1, 1)
	  Goto GatlingDryFireLoop
	  
