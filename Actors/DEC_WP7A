ACTOR FlakClipDrop
{
   Radius 4
   Height 6
   Speed 0
   Scale 0.5
   ReactionTime 175
   BounceSound "Clip/ASR"
   PROJECTILE
   -NOGRAVITY
   +BOUNCEONCEILINGS
   +BOUNCEONFLOORS
   +BOUNCEONWALLS
   +ROLLCENTER
   +ROLLSPRITE
   +DONTSPLASH
   +NOTIMEFREEZE
   Gravity 0.75
   BounceType Doom
   BounceCount 4
   BounceFactor 0.6
   States
   {
   Spawn:
	  TNT1 A 0 NODELAY A_Countdown
	  TNT1 A 0 ThrustThingZ(0,5,0,0)
	  TNT1 A 0 ThrustThing(0,(frandom(-16, 16)))
	  Goto Looper
   Looper:
      CLP5 A 1 A_SetRoll(roll+15, SPF_INTERPOLATE)
      Loop
   Death:
      CLP5 A 0 A_SetRoll(0)
      CLP5 A 0 A_SpawnItemEx("FlakClipLiedown")
      stop
   }
}

actor FlakClipLiedown
{
	-NOGRAVITY
	+FLOORCLIP
	+NOTIMEFREEZE
    Scale 0.5
	States
	{
	Spawn:
	  TNT1 A 0
	  TNT1 A 0 A_Jump(255,"Spawn1","Spawn2")
	  stop
	Spawn1:
	  CLP5 I 1
	  Goto Ded
	Spawn2:
	  CLP5 J 1
	  Goto Ded
	Ded:
	  "####" "#" 210 A_CheckSight("Fadying")
	  Loop
	Fadying:
	  "####" "#" 1 A_FadeOut(0.1)
	  Wait
   }
}

