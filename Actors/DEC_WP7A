Actor Incinerator : IR2Weapon
{
  //$Category IR_Weapons
  //$Title FC-GP6 Incinerator
  //$Sprite VOLGX0
  obituary "%o got roasted by %k's FC-GP6."
  radius 20
  height 16
  Tag "FC-GP6 Incinerator"
  inventory.pickupmessage "You got the FC-GP6 ''Incinerator'' Napalm Torch! Sometimes you need way more gun."
  Inventory.PickupSound "misc/w_pkup"
  Weapon.ReadySound "Flamer/PilotLoop"
  scale 0.55
  +NOEXTREMEDEATH
  +NOAUTOAIM
  +WEAPON.AMMO_OPTIONAL
  +UNDROPPABLE
  +INVENTORY.UNCLEARABLE
  weapon.bobstyle smooth
  weapon.bobrangeX 0.4
  weapon.bobrangeY 0.6
  weapon.bobspeed 2.5
  weapon.slotnumber 6
  weapon.kickback 10
  weapon.ammotype "GimmieFuel" //Gimme Fire! Gimmie That Which I Desire!
  Weapon.AmmoType2 "Flame_Cannister"
  weapon.ammouse 1
  weapon.ammouse2 0
  Weapon.AmmoGive2 1
  weapon.weaponscalex 1.2
  IR2Weapon.BulletGraphics "graphics/MikkOS/NoBullet.png", "TNT1A0"
  states
  {
  Ready:
    VOLG ABCDEF 1 A_WeaponReady(WRF_ALLOWRELOAD)
    loop
  Select:
	  TNT1 A 0 A_JumpIfInventory("MutilatorFirstTime",1,"FirstTime")
	  Goto SelectAuto
  FirstTime:
	  TNT1 A 0 A_StartSound("RW/SLOT7A",251,0,2.0,2)
  SelectAuto:
	  TNT1 A 0 A_TakeInventory("MutilatorFirstTime",1)
	  TNT1 A 0 A_SetCrosshair(9)
	  TNT1 A 1
	  VOLS A 1 A_PlaySound("Weapons/CS_Select", CHAN_WEAPON)
	  TNT1 A 0 SetPlayerProperty(0,0,2)
	  VOLS ABCDEFGHI 1
	  TNT1 A 0 A_StartSound("Flamer/RelRack1",CHAN_5,0,0.66,2)
	  VOLS JKLMN 1
  SelectLoopAuto:
	  VOLG A 1 A_Raise
	  Goto SelectLoopAuto
  Deselect:
	  TNT1 A 0 A_StopSound(CHAN_Weapon)
	  TNT1 A 0 A_StopSound(CHAN_Body)
	  TNT1 A 0 A_StopSound(CHAN_5)
	  TNT1 A 0 A_StopSound(CHAN_6)
	  TNT1 A 0 A_StopSound(CHAN_7)
	  TNT1 A 0 A_SetCrosshair(1)
	  VOLS I 1 A_PlaySound("Weapons/CS_Deselect", CHAN_WEAPON)
	  TNT1 A 0 SetPlayerProperty(0,1,2)
	  VOLS IHGFEDCBA 1
	  TNT1 A 2 
  DeselectLoop:
	  TNT1 A 0 A_StopSound(CHAN_Weapon)
	  TNT1 A 0 A_StopSound(CHAN_Body)
	  TNT1 A 0 A_StopSound(CHAN_5)
	  TNT1 A 0 A_StopSound(CHAN_6)
	  TNT1 A 0 A_StopSound(CHAN_7)
	  TNT1 A 1 A_Lower
	  Goto deselectLoop
  Fire: //Pre-Detonated Flak Shell
    D3SG A 0 A_JumpIfInventory("GimmieFuel",1,1)
    Goto DryFire
     TNT1 A 0 A_StartSound("Flamer/RelRack1",CHAN_5,0,0.66,2)
	VOLF A 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF B 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF C 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF D 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_StartSound("Flamer/Start",CHAN_6,0,1.0,2)
	TNT1 A 0 A_SpawnItem("Lightprojectile",0,0,0,0)
  Hold:
  HoldThatBitchDown:
	D3SG A 0 A_JumpIfInventory("GimmieFuel",1,1)
    Goto DryHoldSound
	TNT1 A 0 A_SpawnItem("Lightprojectile",0,0,0,0)
	TNT1 A 0 A_StartSound("Flamer/MainLoop",CHAN_Weapon,CHANF_Looping,0.88,2)
	TNT1 A 0 A_StartSound("Flamer/AddLoop",CHAN_Body,CHANF_Looping,1.0,2)
	TNT1 A 0 A_Overlay(-3, "GunFlash2")
	TNT1 A 0 A_FireProjectile("FlamethrowerMissileNew",frandom(-2,2),1,12,-2,0,frandom(-2,2))
	VOLF E 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_Overlay(-3, "GunFlash2")
	TNT1 A 0 A_FireProjectile("FlamethrowerMissileNew",frandom(-2,2),1,12,-2,0,frandom(-2,2))
	VOLF F 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_Overlay(-3, "GunFlash2")
	TNT1 A 0 A_FireProjectile("FlamethrowerMissileNew",frandom(-2,2),1,12,-2,0,frandom(-2,2))
	VOLF G 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_Overlay(-3, "GunFlash2")
	TNT1 A 0 A_FireProjectile("FlamethrowerMissileNew",frandom(-2,2),1,12,-2,0,frandom(-2,2))
	VOLF H 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_Overlay(-3, "GunFlash2")
	TNT1 A 0 A_FireProjectile("FlamethrowerMissileNew",frandom(-2,2),1,12,-2,0,frandom(-2,2))
	VOLF I 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_Overlay(-3, "GunFlash2")
	TNT1 A 0 A_FireProjectile("FlamethrowerMissileNew",frandom(-2,2),1,12,-2,0,frandom(-2,2))
	VOLF J 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_Refire("HoldThatBitchDown")
	Goto Release
  Release:
	TNT1 A 0 A_StartSound("Flamer/Stop",CHAN_Body,0,1.0,2)
	TNT1 A 0 A_StartSound("Flamer/RelRack2",CHAN_Weapon,0,0.66,2)
	VOLF K 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF L 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF M 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF N 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF O 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF P 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	Goto Ready
  DryFire:
	TNT1 A 0 A_JumpIfInventory("MutilatorDryToken",1,"DryB")
  DryA:
	TNT1 A 0 A_PlaySound("Flamer/RelRack1",CHAN_6,0.66,0,2)
	VOLF A 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF B 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF C 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF D 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	Goto DryHoldSound
  DryB:
	TNT1 A 0 A_PlaySound("Flamer/RelRack1",CHAN_6,0.66,0,2)
	VOLF A 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF B 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF C 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF D 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	Goto DryHold
  DryHoldSound:
	TNT1 A 0 A_StopSound(CHAN_Body)
	TNT1 A 0 A_PlaySound("Flamer/Stop",CHAN_Weapon,1.0,0,2)
	VOLF EFGHIJ 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_GiveInventory("MutilatorDryToken",1)
	Goto DryHold
  DryHold:
	VOLF EFGHIJ 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_Refire("DryHold")
	Goto DryRelease
  DryRelease:
	TNT1 A 0 A_PlaySound("Flamer/RelRack2",CHAN_6,0.66,0,2)
	VOLF K 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF L 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF M 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF N 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF O 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF P 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	Goto Ready
  Reload: //Plasma Vent
    QURL A 0 A_JumpIfInventory("GimmieFuel",1,"Ready")
	QURL A 0 A_JumpIfInventory("Flame_Cannister",1,1)
	Goto DryFire
  ReloadBegin:
	VOLF A 0 A_PlaySound("Flamer/RelRack1",CHAN_5,0.66,0,2)
    VLR1 ABCDEFGHI 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_PlaySound("Flamer/Reload1",CHAN_6,1.0,0,2)
	VLR1 JKLMNO 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_PlaySound("Flamer/Reload2",CHAN_5,1.0,0,2)
	TNT1 A 0 A_SpawnItemEx("FlakClipDrop",0,0,20)
	VLR1 O 12 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
  ReloadWork:
	QURL M 0 A_TakeInventory("Flame_Cannister",1)
	QURL M 0 A_GiveInventory("GimmieFuel",180)
	QURL M 0 A_JumpIfInventory("GimmieFuel",180,"ReloadFinish")
	QURL M 0 A_JumpIfInventory("Flame_Cannister",1,"ReloadWork")
  ReloadFinish:
    VLR1 O 15 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_PlaySound("Flamer/Reload3",CHAN_6,1.0,0,2)
	VLR2 ABCDEF 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_PlaySound("Flamer/Reload1",CHAN_7,1.0,0,2)
	VLR2 GHIJKLM 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	TNT1 A 0 A_PlaySound("Flamer/Reload4",CHAN_5,1.0,0,2)
	VLR2 NOPQ 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF A 0 A_PlaySound("Flamer/RelRack1",CHAN_6,0.66,0,2)
	VLR2 RSTU 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	VOLF A 0 A_PlaySound("Flamer/RelRack2",CHAN_7,0.66,0,2)
	VLR2 VWXYZ 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH)
	Goto Ready
  GunFlash1:
		TNT1 A 0 A_OverlayFlags(-3, PSPF_ALPHA|PSPF_RENDERSTYLE, true)
		TNT1 A 0 A_OverlayRenderstyle(-3, STYLE_Add)
		TNT1 A 0 A_OverlayAlpha(-3, 0.6)
		TNT1 A 1 Bright 
			{
			A_FireProjectile("HCannonFX", 0, 0, 12, -7, FPF_NOAUTOAIM);
			}
		TNT1 A 0 A_OverlayAlpha(-3, 9.0)
		TNT1 A 0 A_SpawnItem("LightProjectile1",0,0,0,0)
		TNT1 A 1 Bright
		Stop
  GunFlash2:
		TNT1 A 0 A_OverlayFlags(-3, PSPF_ALPHA|PSPF_RENDERSTYLE, true)
		TNT1 A 0 A_OverlayRenderstyle(-3, STYLE_Add)
		TNT1 A 0 A_OverlayAlpha(-3, 0.6)
		TNT1 A 1 Bright 
			{
			A_FireProjectile("TyphoonFX", 0, 0, 14, -2, FPF_NOAUTOAIM);
			}
		TNT1 A 0 A_OverlayAlpha(-3, 9.0)
		TNT1 A 0 A_SpawnItem("LightProjectile1",0,0,0,0)
		TNT1 A 1 Bright
		Stop
  Spawn:
    VOLG X -1
    loop
	}
}


ACTOR MutilatorFirstTime : Inventory {Inventory.MaxAmount 1 Inventory.InterHubAmount 1}

ACTOR MutilatorDryToken : Inventory {Inventory.MaxAmount 1 Inventory.InterHubAmount 1}

ACTOR GimmieFuel : Ammo
{
  Inventory.PickupMessage "You shouldn't see this!"
  Inventory.Amount 0
  Inventory.MaxAmount 180
  Ammo.BackpackAmount 0
  Ammo.BackpackMaxAmount 180
  States
  {
  Spawn:
    TNT1 A -1
    Stop
  }
}

actor Flame_Cannister : ammo 27120 {
  radius 16
  height 8
  scale 0.5
  inventory.pickupmessage "You picked up a Hellbreath Fuel Cartrige for the Incinerator"
  inventory.pickupsound "Flamer/RelRack2"
  Tag "Hellbreath Cannister"
  inventory.amount 1
  inventory.maxamount 2
  ammo.backpackamount 1
  ammo.backpackmaxamount 4
  +UNDROPPABLE
  +INVENTORY.UNCLEARABLE
  states
  {
