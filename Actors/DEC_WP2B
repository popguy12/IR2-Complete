actor gshot_shockwavemini {
	//scale 0.27
	var int user_scale;
	renderstyle add
	+NOTELEPORT
	+NOCLIP
	+FLOORCLIP
	+NOGRAVITY
	+FORCEXYBILLBOARD
	+NOTIMEFREEZE
	+NOINTERACTION
	+CLIENTSIDEONLY
	alpha 0.75
	states{
		spawn:
			TNT1 A 0
			TNT1 A 0 A_SetUserVar("user_scale",1) 
		scaledown:			   
			TNT1 A 0 A_SetScale((user_scale*0.02)) //Start scale
			TNT1 A 0 A_JumpIf(user_scale>=15,"LoopEnd") //Maximum Scale
			BSW0 A 1 bright A_FadeOut(0.05)
			TNT1 A 0 A_SetUserVar("user_scale",user_scale+3) //Speed
			loop
		loopend:
			BSW0 A 1 Bright A_FadeOut(0.05)
			wait
	}
}

