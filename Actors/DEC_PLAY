ACTOR Action_Taunt : CustomInventory
{
   Inventory.Amount 1
   Inventory.MaxAmount 1
   +UNDROPPABLE

   States
   {
       Use:
	   TNT1 A 0 A_AlertMonsters(128)
       TNT1 A 1 A_StartSound("RW/GTaunt",252,0,2.0,2)
       Fail
   }
}

actor GetRektScrub : CustomInventory
{
	States
	{
	Pickup:
		TNT1 A 0 A_AlertMonsters
		stop
	}
}
