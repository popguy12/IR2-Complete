ACTOR IsMerc1 : Inventory {Inventory.MaxAmount 1 Inventory.InterHubAmount 1}
ACTOR IsMerc2 : Inventory {Inventory.MaxAmount 1 Inventory.InterHubAmount 1}
ACTOR AlreadySeenIt : Inventory {Inventory.MaxAmount 1 Inventory.InterHubAmount 1 +INVENTORY.UNDROPPABLE}

ACTOR Mercenary1 : PlayerPawn //Player Loadout 1 : Punisher/Tormentor
{
	Health 125
	Radius 16
	Height 56
	Mass 100
	PainChance 255
	Bloodcolor "7F0000"
	DamageFactor "ChaosDamage", 0
    DamageFactor "trigger_step", 0
    DamageFactor "trigger_runStep", 0
    DamageFactor "ai_breakable", 0
	DamageFactor "GaussExplosion", 0
	DamageFactor "IncreasedRange", 0
	Player.ForwardMove 0.90, 0.60
    Player.SideMove 0.70, 0.50
	Player.GruntSpeed 5
	Player.JumpZ 8
	Player.ColorRange 112, 127
	Player.CrouchSprite "PLYC"
	Player.MaxHealth 125
	Player.DisplayName " ุ "
	Player.StartItem "IsMerc1", 1
	Player.StartItem "StartingToken", 1 //Stronghold Compatibility
	Player.StartItem "Action_Taunt", 1
	Player.StartItem "HealthStim", 5
	Player.StartItem "MalefactorFirstTime", 1
	Player.StartItem "ArchangelFirstTime", 1
	Player.StartItem "DusterFirstTime", 1
	Player.StartItem "ImpalerFirstTime", 1
	Player.StartItem "OmenFirstTime", 1
	Player.StartItem "PDWFirstTime", 1
	Player.StartItem "LonginusFirstTime", 1
	Player.StartItem "MaulerCannonFirstTime", 1
	Player.StartItem "MutilatorFirstTime", 1
	Player.StartItem "TyphoonFirstTime", 1
	Player.StartItem "GaussFirstTime", 1
	Player.StartItem "HarbingerFirstTime", 1
	Player.StartItem "StartingShield", 1
	Player.StartItem "Tormentor", 1
	Player.StartItem "HeavyPistolAmmo", 5
	Player.StartItem "Punisher", 1
	Player.StartItem "LightPistolAmmo", 5
	Player.StartItem "IR2PunchDagger", 1
	Player.StartItem "TNT1Ammo", 1
	Player.StartItem "PunisherClip", 24
	Player.StartItem "TormentorCylinder", 5
	Player.StartItem "10GaugeShells", 9
	Player.StartItem "ArchClip", 20
	Player.StartItem "DusterShells", 4
	Player.StartItem "NailgunLoaded", 63
	Player.StartItem "OmenClip", 80
	Player.StartItem "PDWClip", 180
	Player.StartItem "SniperShells", 5
	Player.StartItem "MaulerClip", 20
	Player.StartItem "GimmieFuel", 300
	Player.StartItem "LeadClip", 900
	Player.StartItem "Railgun_Clip", 4
	Player.StartItem "HarbingerFeed", 235
	Player.StartItem "MobilityStamina", 360
	Player.Portrait "STATSLO1"
	Player.SoundClass "Merc"
	Player.WeaponSlot 1, IR2PunchDagger, Sword //1/1
	Player.WeaponSlot 2, Punisher, Tormentor, StormHound, DevastatorPistol //4/4
	Player.WeaponSlot 3, Malefactor, Archangel //2/2
	Player.WeaponSlot 4, BoneDuster, ImpalerNailgun //2/2
	Player.WeaponSlot 5, Omen, Hellstorm //2/2
	Player.WeaponSlot 6, MaulerCannon, Longinus
	Player.WeaponSlot 7, Incinerator, Typhoon //1/1
	Player.WeaponSlot 8, Evangelizer, Harbinger //2/2
	States
	{
  Spawn:
    PLAY AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA 1 A_JumpIf(momz >> 0, "Jumping")
    Loop
  See:
	PLAY AAAAA 1 A_JumpIf(momz >> 0, "Jumping")
	PLAY BBBBB 1 A_JumpIf(momz >> 0, "Jumping")
	PLAY CCCCC 1 A_JumpIf(momz >> 0, "Jumping")
	PLAY DDDDD 1 A_JumpIf(momz >> 0, "Jumping")
    Goto Spawn
  Jumping:
    PLAJ A 1
    PLAJ A 0 A_CheckFloor("Spawn")
    goto Jumping
  Missile:
    PLAY EF 4 BRIGHT
    Goto Spawn
  Melee:
    PLAY E 4
    Goto Spawn
  Pain:
    PLAY G 4 
    PLAY G 4 A_Pain
    Goto Spawn
  Pain.Yeet:
    TNT1 A 0 A_Recoil(12)
	TNT1 A 0 ThrustThingZ(0,15,0,1)
    PLAY G 4 
    PLAY G 4 A_Pain
    Goto Spawn
  Death:
    PLAY H 0 A_PlayerSkinCheck("AltSkinDeath")
  Death1:
    TNT1 A 0 A_GiveToTarget("ShitMyPlayerSaysWhenHeKillsShit",1)
    PLAY H 10
    PLAY I 10 A_PlayerScream
    PLAY J 10 A_NoBlocking
    PLAY KLM 10
    PLAY N -1
    Stop
  XDeath:
    PLAY O 0 A_PlayerSkinCheck("AltSkinXDeath")
  XDeath1:
	TNT1 A 0 A_GiveToTarget("ShitMyPlayerSaysWhenHeKillsShit",1)
    PLAY O 5
    PLAY P 5 A_XScream
    PLAY Q 5 A_NoBlocking
    PLAY RSTUV 5
    PLAY W -1
    Stop
  AltSkinDeath:
	TNT1 A 0 A_GiveToTarget("ShitMyPlayerSaysWhenHeKillsShit",1)
    PLAY H 10
    PLAY I 10 A_PlayerScream
    PLAY J 10 A_NoBlocking
    PLAY KLM 10
    PLAY N -1
    Stop
  AltSkinXDeath:
    TNT1 A 0 A_GiveToTarget("ShitMyPlayerSaysWhenHeKillsShit",1)
    PLAY O 5
    PLAY P 5 A_XScream
    PLAY Q 5 A_NoBlocking
    PLAY RSTUV 5
    PLAY W -1
    Stop
  Burn:
	TNT1 A 0 A_GiveToTarget("ShitMyPlayerSaysWhenHeSetsShitOnFire",1)
	BURN A 3 Bright A_PlaySound("misc/burn",CHAN_AUTO)
	BURN B 3 Bright A_PlaySound("RW/Burnt",CHAN_AUTO,1.99,0,1,1)
	BURN C 3 Bright A_PlaySound("misc/flame",CHAN_AUTO)
	BURN D 3 Bright A_NoBlocking
	BURN EFGHIJKLMNOP 3 Bright 
	BURN Q 3 Bright A_PlaySound("misc/bodyhit",CHAN_VOICE)
	BURN RSTU 3 Bright 		
	BURN V -1
	goto Death
  }
}

