//health stims
actor HealthStim : CustomInventory 26100 {
  inventory.amount 1
  inventory.maxamount 20
  inventory.interhubamount 20
  inventory.icon "HSTMA0"
  inventory.pickupsound "items/hstim_up"
  inventory.pickupmessage "picked up a Medstim Injector [+80 Health]"
  Tag"Medstim Injector [+80 Health]"
  scale 0.28
  +INVENTORY.UNCLEARABLE
  +INVENTORY.INVBAR
  +COUNTITEM
  states{
  	Spawn:
		HSTI A -1
		loop
	Use:
		TNT1 A 0
		TNT1 A 0 A_PlaySound("items/stimshot",CHAN_BODY,1.0,0,1)
		TNT1 A 0 A_GiveInventory("lifeup", 1)
		fail
	}
}

actor HealthPack : CustomInventory 26101 {
	scale 0.28
	Inventory.PickupMessage "Pack of two Medstim Injectors [+80 Health]"
	inventory.pickupsound "items/hpack_up"
	Tag "Medstim Injectors X2 [+80 Health]"
	//+INVENTORY.ALWAYSPICKUP
	+INVENTORY.UNCLEARABLE
	-INVENTORY.INVBAR
    +COUNTITEM
	States{
		Spawn:
			MPAK A -1
			stop
		Pickup:
			TNT1 A 0 A_JumpIfInventory("healthstim",20,"PickupFail")
			TNT1 A 0 A_GiveInventory("healthstim", 2)
			stop
		PickupFail:
			TNT1 A 0
			fail
	}

}




