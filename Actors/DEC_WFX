Actor MuzzleSmoke
{
	RenderStyle Add
	Alpha 1.0
	Scale 0.25
	VSpeed -0.25
	+NOINTERACTION
	+FORCEXYBILLBOARD
	+NOTIMEFREEZE
	+NOGRAVITY
	+ROLLSPRITE
	States
	{
	Spawn:
		TNT1 A 1 A_Jump(256,"SpawnVar1","SpawnVar2","SpawnVar3")
		Goto Death
	SpawnVar1:
		SMK1 ABCDEFGH 2{
		A_SetRoll(roll-12,SPF_INTERPOLATE);
		A_FadeTo(0.0,0.05,false);
		}
		Goto Death
	SpawnVar2:
		SMK2 ABCDEFGH 2{
		A_SetRoll(roll-12,SPF_INTERPOLATE);
		A_FadeTo(0.0,0.05,false);
		}
		Goto Death
	SpawnVar3:
		SMK3 ABCDEFGH 2{
		A_SetRoll(roll-12,SPF_INTERPOLATE);
		A_FadeTo(0.0,0.05,false);
		}
		Goto Death
	Death:
		TNT1 A 1
		Stop
	}
}

