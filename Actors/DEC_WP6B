		SNR5 ABCDEFGHIJKMNOP 1 A_WeaponReady(WRF_NOFIRE)
		SNPI A 5 A_WeaponReady(WRF_NOFIRE)
		Goto Ready
	Zoom:
	ReloadBegin_EXP:
		TNT1 A 0 A_JumpIfInventory("SniperShells",5,"Ready")
		TNT1 A 0 A_JumpIfInventory("Sniper_Reserve",1,1)
		Goto DryFire
		TNT1 A 0 A_PlaySound("Weapons/SniperBoltBack",CHAN_6,1.0,0,2)
		SNR1 ABCDEFGHIJKL 1 A_WeaponReady(WRF_NOFIRE)
		//TNT1 A 0 A_PlaySound("Weapons/SniperEjectS1",CHAN_7,1.0,0,2)
		SNR1 LLLLL 1 A_WeaponReady(WRF_NOFIRE)
		TNT1 A 0 A_FireProjectile("TRifle_EXPCasingSpawner", -5, 0, 0, 0)
		TNT1 A 0 A_PlaySound("Weapons/SniperSequence1",CHAN_6,1.0,0,2)
		SNR2 ABCDEFHIJKLM 1 A_WeaponReady(WRF_NOFIRE)
		TNT1 A 0 A_PlaySound("Weapons/SniperSequence2",CHAN_5,1.0,0,2)
		SNR3 ABCDEFGHI 1 A_WeaponReady(WRF_NOFIRE)
		TNT1 A 0 A_SpawnItemEx("LonginusClipDrop",0,0,20)
		SNR3 I 10 A_WeaponReady(WRF_NOFIRE)
	ReloadWork_EXP:
		ATPR G 0 A_TakeInventory("Sniper_Reserve",2)
		ATPR G 0 A_GiveInventory("SniperShells",5)
		ATPR G 0 A_JumpIfInventory("SniperShells",5,"ReloadFinish_EXP")
		ATPR G 0 A_JumpIfInventory("Sniper_Reserve",1,"ReloadWork_EXP")
	ReloadFinish_EXP:
		TNT1 A 0 A_PlaySound("Weapons/SniperSequence3",CHAN_6,1.0,0,2)
		SNR4 ABCDEFGHIJKLMN 1 A_WeaponReady(WRF_NOFIRE)
		TNT1 A 0 A_PlaySound("Weapons/SniperSequence4",CHAN_7,1.0,0,2)
		SNR4 OPQRSTUVWXYZ 1 A_WeaponReady(WRF_NOFIRE)
		TNT1 A 0 A_PlaySound("Weapons/SniperBoltForward",CHAN_6,1.0,0,2)
		SNR5 ABCDEFGHIJKMNOP 1 A_WeaponReady(WRF_NOFIRE)
		SNPI A 5 A_WeaponReady(WRF_NOFIRE)
		TNT1 A 0 A_GiveInventory("SniperToken",1)
		Goto Ready
