//***** Animators ***********************************************************//

fader FastGoAway
{
	DecayStart	0.2
	DecayTime	0.5
}

fader GoAway
{
	DecayStart	0.5
	DecayTime	1.0
}

fader GoAway2
{
	DecayStart	1.0
	DecayTime	3.0
}

colorchanger ToBlack
{
	FadeStart	0.5
	FadeTime	1.0
}

colorchanger ToBlackSlow
{
	FadeStart	0.5
	FadeTime	2.2
}

colorchanger ToBlackSlowest
{
	FadeStart	0.5
	FadeTime	4.4
}

//***** Bullet Chips *********************************************************//

decal BulletChip1
{
	pic BULLETHL
	translucent 0.85
	shade "00 00 00"
	x-scale 0.1
	y-scale 0.1
	randomflipx
	randomflipy
}

