//Brimstone
fader KyreiFade
{
	DecayStart	0.2
	DecayTime	0.7
}

decal KyreiLowerRight
{
	pic SORDECAL
	translucent 1
	shade "00 00 00"
	x-scale 0.075
	y-scale 0.075
	flipx
}

decal KyreiWallRight
{
	pic SORDECAL
	add 1
	shade "ff 24 00"
	fullbright
	x-scale 0.075
	y-scale 0.075
	flipx
	animator KyreiFade
	lowerdecal KyreiLowerRight
}

decal KyreiLowerLeft
{
	pic SORDECAL
	translucent 1
	shade "00 00 00"
	x-scale 0.075
	y-scale 0.075
}

decal KyreiWallLeft
{
	pic SORDECAL
	add 1
	shade "ff 24 00"
	fullbright
	x-scale 0.075
	y-scale 0.075
	animator KyreiFade
	lowerdecal KyreiLowerLeft
}