	  VORL C 1 A_WeaponReady(WRF_NOBOB|WRF_NOFIRE);
	  //TNT1 A 0 HXA_CustomRollAttack(damage: 2, healfactor: 0.5, PierceEnemies: FALSE, roll: -45, area: 45, dist: 48);
	  TNT1 A 0 Bright A_FireProjectile("BladeSlash2",0,1,0,0);
	  //TNT1 A 0 HXA_CustomRollAttack(damage: 2, healfactor: 0.5, PierceEnemies: FALSE, roll: -45, area: 45, dist: 48);
