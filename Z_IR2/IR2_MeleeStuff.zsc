Class RedParticleSpawner : Actor {

	Default {
	+NoBlockMap 
	+NoGravity 
	+NoSector 
	+NoInteraction 
	+NoClip 
	-Solid 
	+CLIENTSIDEONLY
	+NOTIMEFREEZE
	}
        states
        {
        Spawn:
        	TNT1 A 25;
        	TNT1 A 1 A_SpawnItemEx ("RedRisingEnergy", random(-Args[0], Args[0]), random(-Args[0], Args[0]), random(0, 8), 0, 0, random(1,3), 0, 129, 0);
			Stop;
        }          
}


Class RedRisingEnergy : Actor
{
 Default {
 RenderStyle "Add";
 Radius 0;
 Height 0;
 Alpha 0.01;
 Scale 0.37;
 +Missile
 +NoGravity
 +NoBlockmap
 +NoInteraction
 +NoTimeFreeze
 -Solid
 }
 States
 {
  Spawn:
   KEFX AAAAA 1 Bright A_FadeIn(0.2);
   KEFX AAAAAAAAAAAAAAAA 1 Bright A_FadeOut(0.06);
   Stop;
 }
}