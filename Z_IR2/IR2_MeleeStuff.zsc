	  TNT1 A 0 HXA_CustomRollAttack(damage: 2, healfactor: 0.5, PierceEnemies: FALSE, roll: -45, area: 45, dist: 48, PuffActor: "KyreiPuffLeft", HitActorSound: "Sword/HitMeat", HitWallSound: "Sword/HitWall");
	  VORL B 1 A_WeaponReady(WRF_NOBOB|WRF_NOFIRE);
