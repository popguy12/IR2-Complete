	QUH3 ABCDDD 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH);
	TNT1 AAA 0 A_FireProjectile("gausssmoke_spawner2",0,0,3,4,0);	
	TNT1 A 0 A_StartSound("Leadspitter/ShutterClose",99,0,0.99,2);
	TNT1 A 0 A_TakeInventory("Typhoon_Heat_Index", 999);
//	QUCH ABC 1 A_WeaponReady(WRF_NOFIRE|WRF_NOSWITCH);
	Goto Ready;

  GunFlash1:
		TNT1 A 0 A_OverlayFlags(-3, PSPF_ALPHA|PSPF_RENDERSTYLE, true);
		TNT1 A 0 A_OverlayRenderstyle(-3, STYLE_Add);
		TNT1 A 0 A_OverlayAlpha(-3, 0.6);
		TNT1 A 1 Bright
			{
			A_FireProjectile("TyphoonFX", 0, 0, 10, 1, FPF_NOAUTOAIM);
			}
		TNT1 A 0 A_OverlayAlpha(-3, 9.0);
		TNT1 A 1 Bright;
		Stop;
  GunFlash2:
		TNT1 A 0 A_OverlayFlags(-3, PSPF_ALPHA|PSPF_RENDERSTYLE, true);
		TNT1 A 0 A_OverlayRenderstyle(-3, STYLE_Add);
		TNT1 A 0 A_OverlayAlpha(-3, 0.6);
		TNT1 A 1 Bright
			{
			A_FireProjectile("EvangelizerFX", 0, 0, 10, 1, FPF_NOAUTOAIM);
			}
		TNT1 A 0 A_OverlayAlpha(-3, 9.0);
		TNT1 A 1 Bright;
		Stop;
  Spawn:
    QWOP A -1;
	Stop;
	}
