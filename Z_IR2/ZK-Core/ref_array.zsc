class RefArray abstract
{
    virtual int Size() { return 0; }
    virtual bool Pop() { return false; }
    virtual void Delete(int index, int deleteCount = 1) {}
    virtual void ShrinkToFit() {}
    virtual void Grow(int amount) {}
    virtual void Resize(int amount) {}
    virtual void Reserve(int amount) {}
    virtual int Max() { return 0; }
    virtual void Clear() {}
}

class RefArrayI8 : RefArray
{
    Array<int8> values;

    override int Size() { return values.Size(); }
    override bool Pop() { return values.Pop(); }
    override void Delete(int index, int deleteCount) { values.Delete(index, deleteCount); }
    override void ShrinkToFit() { values.ShrinkToFit(); }
    override void Grow(int amount) { values.Grow(amount); }
    override void Resize(int amount) { values.Resize(amount); }
    override void Reserve(int amount) { values.Reserve(amount); }
    override int Max() { return values.Max(); }
    override void Clear() { values.Clear(); }

    void Copy(RefArrayI8 other) { values.Copy(other.values); }
    void Move(RefArrayI8 other) { values.Move(other.values); }
    int Find(int item) { return values.Find(item); }
    int Push(int item) { return values.Push(item); }
    void Insert(int index, int item) { values.Insert(index, item); }
}

