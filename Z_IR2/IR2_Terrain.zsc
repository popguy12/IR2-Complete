Class IR2_Effect : Actor
{ 
  Default
  {
  +DONTSPLASH
  DistanceCheck "ir2_effectdistance";
  }
  
  bool tickin;
  
  private int dcye;
  flagdef choking: dcye, 0;
  
  States { Spawn: TNT1 A 0; Stop; }
}

Class IR2_WaterParticleX : IR2_Effect
{
  Default
  {
  Height 0;
  Radius 0;
  Mass 0;
  +Missile
  +NoBlockMap
  -NoGravity
  +DontSplash
  +DoomBounce
  +FORCEXYBILLBOARD
  +NOCLIP
  +CLIENTSIDEONLY
  BounceFactor 0.1;
  Gravity 0.5;
  RenderStyle "Add";
  Scale 1.0;
  Alpha 0.5;
  Speed 2;
  }
  
  States
  {
  Spawn:
	TNT1 A 1;
	TNT1 A 1 { bUseBounceState = false; }
	Goto Stand;
  Stand:
    WSPH ABCD 4;
    Stop;
  Death:
	TNT1 A 1;
	Stop;
  }
}


Class IR2_WaterParticleXFaster: IR2_WaterParticleX { Default { Speed 4; } }

// -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=
// =-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-

//********** Splashes **********

Class IR2_WaterSplashBase2 : Actor
{
  Default
  {
  Radius 1;
  Height 1;
  Mass 1;
  Alpha .6;
  Scale 0.7;
  +DONTSPLASH
  +NOGRAVITY
  +NOCLIP
  }
  
  States
  {
  Spawn:
	TNT1 F 0 NoDelay
	{
		for (int i = 6; i > 0; i--)
		{
			A_SpawnProjectile("IR2_WaterParticleX", 2, random(-5,5), frandom(0, 360), 2, frandom(-50, -140));
			A_SpawnProjectile("IR2_WaterParticleXFaster", 2, random(-5,5), frandom(0, 360), 2, frandom(-50, -140));
		}
	}
	WSPL ABCDEFGHIJKLMNOPQRSTUVWXYZ 1;
    Stop;
  }
}


