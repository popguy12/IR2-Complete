////////////////////////Lava

Class IR2_LavaParticleX : IR2_Effect
{
  Default
  {
  Height 0;
  Radius 0;
  Mass 0;
  +Missile
  +NoBlockMap
  -NoGravity
  +DontSplash
  +DoomBounce
  +FORCEXYBILLBOARD
  +NOCLIP
  +CLIENTSIDEONLY
  +BRIGHT
  BounceFactor 0.1;
  Gravity 0.5;
  RenderStyle "Add";
  Translation "0:255=%[0.27,0.00,0.00]:[2.00,0.76,0.00]";
  Scale 1.0;
  Alpha 0.8;
  Speed 2;
  }
  
  States
  {
  Spawn:
	TNT1 A 1;
	TNT1 A 1 { bUseBounceState = false; }
	Goto Stand;
  Stand:
    LSPH ABCD 4;
    Stop;
  Death:
	TNT1 A 1;
	Stop;
  }
}


Class IR2_LavaParticleXFaster : IR2_LavaParticleX { Default { Speed 4; } }

Class IR2_LavaSplashBase1 : Actor
{
  Default
  {
  Radius 1;
  Height 1;
  Mass 1;
  Alpha .6;
  Scale 0.7;
  +NOCLIP
  +DONTSPLASH
  +NOGRAVITY
  +BRIGHT
  +NODAMAGETHRUST
  }
  
  States
  {
  Spawn:
    TNT1 F 0 NoDelay
	{
		for (int i = 6; i > 0; i--)
		{
			A_SpawnProjectile("IR2_LavaParticleX", 2, random(-5,5), frandom(0, 360), 2, frandom(-50, -140));
			A_SpawnProjectile("IR2_LavaParticleXFaster", 2, random(-5,5), frandom(0, 360), 2, frandom(-50, -140));
		}
		
		A_SpawnParticleEx(0x000000, TexMan.CheckForTexture("graphics/Particles/dcygas.png"), STYLE_TRANSLUCENT, SPF_RELATIVE|SPF_ROLL, 90, 40, 0, frandom(-1, 1), frandom(-1, 1), frandom(-1, 1), frandom(-0.1, 0.1), frandom(-0.1, 0.1), frandom(0.3, 1), startalphaf: 0.5, fadestepf: 0.01, startroll: frandom(0, 360), rollvel: random(0, 1) ? 0.1 : -0.1);
	}
    LSPL ABCDEFGHIJKLMNOPQRSTUVWXYZ 2;
    Stop;
  }
}

