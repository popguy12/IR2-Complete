// SmartGun --------------------------------------------------------------------

Model SmartBeam_Segment
{ 
   Path "Models/SmartGun"
   Skin 0 "BEAM.png" 
   Model 0 "segment.md3" 
   Scale 10.0 10.0 10.0
   ZOffset 2;
   USEACTORPITCH
   USEACTORROLL
   
   FrameIndex MODL A 0 0 
}

