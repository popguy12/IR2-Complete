{
   Path "Models/Sparks"    // Path to model in PK3
   Model 0 "spark.md3"    // Model index, model file
   Skin 0 "redspark.png"     // Model index, texture (can be in any format supported by GZDoom)
   Scale 1.5 1.5 6.0 // Scale values
   DONTCULLBACKFACES
   PITCHFROMMOMENTUM // A flag that will fix the model pitch for projectiles
   FrameIndex SPKO S 0 0         // The sprite lump, sprite frame, model index, frame number
}

